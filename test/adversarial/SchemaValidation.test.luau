--!strict
--!optimize 2
local Gate = require(script.Parent.Parent.Parent.transport.Gate)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Gate.validate: int codec", function(): ()
    it("accepts valid int", function(): () local ok, _ = Gate.validate(128, Lync.int(0, 255)); expect(ok):toBe(true) end)
    it("accepts min boundary", function(): () local ok, _ = Gate.validate(0, Lync.int(0, 255)); expect(ok):toBe(true) end)
    it("accepts max boundary", function(): () local ok, _ = Gate.validate(255, Lync.int(0, 255)); expect(ok):toBe(true) end)
    it("rejects wrong typeof", function(): () local ok, _ = Gate.validate("hello", Lync.int(0, 255)); expect(ok):toBe(false) end)
    it("rejects boolean", function(): () local ok, _ = Gate.validate(true, Lync.int(0, 255)); expect(ok):toBe(false) end)
    it("rejects NaN", function(): () local ok, _ = Gate.validate(0/0, Lync.int(0, 255)); expect(ok):toBe(false) end)
    it("rejects inf", function(): () local ok, _ = Gate.validate(math.huge, Lync.int(0, 255)); expect(ok):toBe(false) end)
    it("rejects non-integer", function(): () local ok, _ = Gate.validate(1.5, Lync.int(0, 255)); expect(ok):toBe(false) end)
    it("rejects below min", function(): () local ok, _ = Gate.validate(5, Lync.int(10, 50)); expect(ok):toBe(false) end)
    it("rejects above max", function(): () local ok, _ = Gate.validate(100, Lync.int(10, 50)); expect(ok):toBe(false) end)
    it("rejects negative for unsigned", function(): () local ok, _ = Gate.validate(-1, Lync.int(0, 255)); expect(ok):toBe(false) end)
end)

describe("Gate.validate: bool codec", function(): ()
    it("accepts true", function(): () local ok, _ = Gate.validate(true, Lync.bool); expect(ok):toBe(true) end)
    it("accepts false", function(): () local ok, _ = Gate.validate(false, Lync.bool); expect(ok):toBe(true) end)
    it("rejects number", function(): () local ok, _ = Gate.validate(1, Lync.bool); expect(ok):toBe(false) end)
    it("rejects string", function(): () local ok, _ = Gate.validate("true", Lync.bool); expect(ok):toBe(false) end)
    it("rejects nil", function(): () local ok, _ = Gate.validate(nil, Lync.bool); expect(ok):toBe(false) end)
end)

describe("Gate.validate: float codec", function(): ()
    it("accepts in-range", function(): () local ok, _ = Gate.validate(50, Lync.float(0, 100, 0.5)); expect(ok):toBe(true) end)
    it("rejects NaN", function(): () local ok, _ = Gate.validate(0/0, Lync.float(0, 100, 0.5)); expect(ok):toBe(false) end)
    it("rejects inf", function(): () local ok, _ = Gate.validate(math.huge, Lync.float(0, 100, 0.5)); expect(ok):toBe(false) end)
    it("rejects wrong type", function(): () local ok, _ = Gate.validate("hi", Lync.float(0, 100, 0.5)); expect(ok):toBe(false) end)
end)

describe("Gate.validate: struct schema", function(): ()
    it("accepts valid struct", function(): ()
        local c = Lync.struct({ hp = Lync.int(0, 100), name = Lync.string })
        local ok, _ = Gate.validate({ hp = 50, name = "test" }, c); expect(ok):toBe(true)
    end)
    it("rejects missing field", function(): ()
        local c = Lync.struct({ hp = Lync.int(0, 100), name = Lync.string })
        local ok, _ = Gate.validate({ hp = 50 }, c); expect(ok):toBe(false)
    end)
    it("rejects wrong field type", function(): ()
        local c = Lync.struct({ hp = Lync.int(0, 100) })
        local ok, _ = Gate.validate({ hp = "not a number" }, c); expect(ok):toBe(false)
    end)
    it("rejects out-of-range nested field", function(): ()
        local c = Lync.struct({ hp = Lync.int(0, 100) })
        local ok, _ = Gate.validate({ hp = 200 }, c); expect(ok):toBe(false)
    end)
    it("rejects non-table for struct", function(): ()
        local c = Lync.struct({ hp = Lync.int(0, 100) })
        local ok, _ = Gate.validate("not a table", c); expect(ok):toBe(false)
    end)
    it("validates nested struct", function(): ()
        local inner = Lync.struct({ v = Lync.int(0, 10) })
        local outer = Lync.struct({ child = inner })
        local ok, _ = Gate.validate({ child = { v = 5 } }, outer); expect(ok):toBe(true)
    end)
    it("rejects invalid nested struct", function(): ()
        local inner = Lync.struct({ v = Lync.int(0, 10) })
        local outer = Lync.struct({ child = inner })
        local ok, _ = Gate.validate({ child = { v = 99 } }, outer); expect(ok):toBe(false)
    end)
end)

describe("Gate.validate: f32/f64 fallback scan", function(): ()
    it("f32 accepts clean", function(): () local ok, _ = Gate.validate(1.5, Lync.f32); expect(ok):toBe(true) end)
    it("f64 rejects NaN", function(): () local ok, _ = Gate.validate(0/0, Lync.f64); expect(ok):toBe(false) end)
    it("f32 rejects inf", function(): () local ok, _ = Gate.validate(math.huge, Lync.f32); expect(ok):toBe(false) end)
end)

return nil

--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer =
    Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe ("Group create/destroy", function (): ()
    it ("creates and returns object", function (): ()
        local g = Lync.createGroup ("__g01")
        expect (g):toBeTruthy ()
        expect ((g :: any)._tag):toBe ("group")
        g:destroy ()
    end)
    it ("throws duplicate", function (): ()
        local g = Lync.createGroup ("__g02")
        expect (function (): ()
            Lync.createGroup ("__g02")
        end):toThrow ()
        g:destroy ()
    end)
    it ("throws double destroy", function (): ()
        local g = Lync.createGroup ("__g02b")
        g:destroy ()
        expect (function (): ()
            g:destroy ()
        end):toThrow ("destroyed")
    end)
end)

describe ("Group add/remove/has", function (): ()
    it ("add+has", function (): ()
        local g = Lync.createGroup ("__g03")
        local p = fakePlayer ("A", 1)
        expect (g:add (p)):toBe (true)
        expect (g:has (p)):toBe (true)
        g:destroy ()
    end)
    it ("dup add false", function (): ()
        local g = Lync.createGroup ("__g04")
        local p = fakePlayer ("B", 2)
        g:add (p)
        expect (g:add (p)):toBe (false)
        g:destroy ()
    end)
    it ("remove", function (): ()
        local g = Lync.createGroup ("__g05")
        local p = fakePlayer ("C", 3)
        g:add (p)
        expect (g:remove (p)):toBe (true)
        expect (g:has (p)):toBe (false)
        g:destroy ()
    end)
end)

describe ("Group count", function (): ()
    it ("0 empty", function (): ()
        local g = Lync.createGroup ("__g06")
        expect (g:count ()):toBe (0)
        g:destroy ()
    end)
    it ("increments", function (): ()
        local g = Lync.createGroup ("__g07")
        g:add (fakePlayer ("D", 4))
        g:add (fakePlayer ("E", 5))
        expect (g:count ()):toBe (2)
        g:destroy ()
    end)
    it ("dup no increment", function (): ()
        local g = Lync.createGroup ("__g08")
        local p = fakePlayer ("F", 6)
        g:add (p)
        g:add (p)
        expect (g:count ()):toBe (1)
        g:destroy ()
    end)
end)

describe ("Group forEach", function (): ()
    it ("iterates all", function (): ()
        local g = Lync.createGroup ("__g09")
        local p1, p2 = fakePlayer ("G", 7), fakePlayer ("H", 8)
        g:add (p1)
        g:add (p2)
        local seen = {}
        g:forEach (function (p: any): ()
            seen[p] = true
        end)
        expect (seen[p1]):toBe (true)
        expect (seen[p2]):toBe (true)
        g:destroy ()
    end)
end)

describe ("Group getSet", function (): ()
    it ("returns set table", function (): ()
        local g = Lync.createGroup ("__g10")
        local p = fakePlayer ("I", 9)
        g:add (p)
        local set = g:getSet ()
        expect (set[p]):toBe (true)
        g:destroy ()
    end)
end)

return nil

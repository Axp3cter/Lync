--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer =
    Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe ("Group create/destroy", function (): ()
    it ("creates and destroys", function (): ()
        Lync.createGroup ("__g01")
        Lync.destroyGroup ("__g01")
    end)
    it ("throws duplicate", function (): ()
        Lync.createGroup ("__g02")
        expect (function (): ()
            Lync.createGroup ("__g02")
        end):toThrow ()
        Lync.destroyGroup ("__g02")
    end)
    it ("throws nonexistent destroy", function (): ()
        expect (function (): ()
            Lync.destroyGroup ("__nope")
        end):toThrow ()
    end)
end)

describe ("Group add/remove/has", function (): ()
    it ("add+has", function (): ()
        Lync.createGroup ("__g03")
        local p = fakePlayer ("A", 1)
        expect (Lync.addToGroup ("__g03", p)):toBe (true)
        expect (Lync.hasInGroup ("__g03", p)):toBe (true)
        Lync.destroyGroup ("__g03")
    end)
    it ("dup add false", function (): ()
        Lync.createGroup ("__g04")
        local p = fakePlayer ("B", 2)
        Lync.addToGroup ("__g04", p)
        expect (Lync.addToGroup ("__g04", p)):toBe (false)
        Lync.destroyGroup ("__g04")
    end)
    it ("remove", function (): ()
        Lync.createGroup ("__g05")
        local p = fakePlayer ("C", 3)
        Lync.addToGroup ("__g05", p)
        expect (Lync.removeFromGroup ("__g05", p)):toBe (true)
        expect (Lync.hasInGroup ("__g05", p)):toBe (false)
        Lync.destroyGroup ("__g05")
    end)
end)

describe ("Group count", function (): ()
    it ("0 empty", function (): ()
        Lync.createGroup ("__g06")
        expect (Lync.groupCount ("__g06")):toBe (0)
        Lync.destroyGroup ("__g06")
    end)
    it ("increments", function (): ()
        Lync.createGroup ("__g07")
        Lync.addToGroup ("__g07", fakePlayer ("D", 4))
        Lync.addToGroup ("__g07", fakePlayer ("E", 5))
        expect (Lync.groupCount ("__g07")):toBe (2)
        Lync.destroyGroup ("__g07")
    end)
    it ("dup no increment", function (): ()
        Lync.createGroup ("__g08")
        local p = fakePlayer ("F", 6)
        Lync.addToGroup ("__g08", p)
        Lync.addToGroup ("__g08", p)
        expect (Lync.groupCount ("__g08")):toBe (1)
        Lync.destroyGroup ("__g08")
    end)
end)

describe ("Group forEach", function (): ()
    it ("iterates all", function (): ()
        Lync.createGroup ("__g09")
        local p1, p2 = fakePlayer ("G", 7), fakePlayer ("H", 8)
        Lync.addToGroup ("__g09", p1)
        Lync.addToGroup ("__g09", p2)
        local seen = {}
        Lync.forEachInGroup ("__g09", function (p: any): ()
            seen[p] = true
        end)
        expect (seen[p1]):toBe (true)
        expect (seen[p2]):toBe (true)
        Lync.destroyGroup ("__g09")
    end)
end)

describe ("Group getSet", function (): ()
    it ("returns set table", function (): ()
        Lync.createGroup ("__g10")
        local p = fakePlayer ("I", 9)
        Lync.addToGroup ("__g10", p)
        local set = Lync.getGroupSet ("__g10")
        expect (set[p]):toBe (true)
        Lync.destroyGroup ("__g10")
    end)
end)

return nil

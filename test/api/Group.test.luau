--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer = Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe("Group: add/remove/has/count", function(): ()
    it("add returns true first time", function(): ()
        local g = Lync.group("__g1"); expect(g:add(fakePlayer("P", 1))):toBe(true); g:destroy()
    end)
    it("add returns false on duplicate", function(): ()
        local g = Lync.group("__g2"); local p = fakePlayer("P", 1); g:add(p)
        expect(g:add(p)):toBe(false); g:destroy()
    end)
    it("remove returns true if present", function(): ()
        local g = Lync.group("__g3"); local p = fakePlayer("P", 1); g:add(p)
        expect(g:remove(p)):toBe(true); g:destroy()
    end)
    it("remove returns false if absent", function(): ()
        local g = Lync.group("__g4"); expect(g:remove(fakePlayer("P", 1))):toBe(false); g:destroy()
    end)
    it("has true after add", function(): ()
        local g = Lync.group("__g5"); local p = fakePlayer("P", 1); g:add(p)
        expect(g:has(p)):toBe(true); g:destroy()
    end)
    it("has false after remove", function(): ()
        local g = Lync.group("__g6"); local p = fakePlayer("P", 1); g:add(p); g:remove(p)
        expect(g:has(p)):toBe(false); g:destroy()
    end)
    it("has false for never-added", function(): ()
        local g = Lync.group("__g7"); expect(g:has(fakePlayer("P", 1))):toBe(false); g:destroy()
    end)
    it("count starts at 0", function(): ()
        local g = Lync.group("__g8"); expect(g:count()):toBe(0); g:destroy()
    end)
    it("count increments on add", function(): ()
        local g = Lync.group("__g9"); g:add(fakePlayer("A", 1)); g:add(fakePlayer("B", 2))
        expect(g:count()):toBe(2); g:destroy()
    end)
    it("count decrements on remove", function(): ()
        local g = Lync.group("__g10"); local p = fakePlayer("A", 1); g:add(p); g:add(fakePlayer("B", 2))
        g:remove(p); expect(g:count()):toBe(1); g:destroy()
    end)
    it("duplicate add doesn't inflate count", function(): ()
        local g = Lync.group("__g11"); local p = fakePlayer("A", 1); g:add(p); g:add(p)
        expect(g:count()):toBe(1); g:destroy()
    end)
end)

describe("Group: __iter", function(): ()
    it("iterates all members", function(): ()
        local g = Lync.group("__gi1"); local p1 = fakePlayer("A", 1); local p2 = fakePlayer("B", 2); local p3 = fakePlayer("C", 3)
        g:add(p1); g:add(p2); g:add(p3)
        local seen: { [any]: boolean } = {}
        for player in g do seen[player] = true end
        expect(seen[p1]):toBe(true); expect(seen[p2]):toBe(true); expect(seen[p3]):toBe(true)
        g:destroy()
    end)
    it("empty group = zero iterations", function(): ()
        local g = Lync.group("__gi2"); local count = 0
        for _ in g do count += 1 end
        expect(count):toBe(0); g:destroy()
    end)
    it("single member", function(): ()
        local g = Lync.group("__gi3"); local p = fakePlayer("A", 1); g:add(p)
        local count = 0; local seen: any = nil
        for player in g do count += 1; seen = player end
        expect(count):toBe(1); expect(seen):toBe(p); g:destroy()
    end)
end)

describe("Group: destroy", function(): ()
    it("clears all members", function(): ()
        local g = Lync.group("__gd1"); g:add(fakePlayer("A", 1)); g:add(fakePlayer("B", 2))
        g:destroy(); expect(g:count()):toBe(0)
    end)
    it("frees name for reuse", function(): ()
        Lync.group("__gd2"):destroy()
        Lync.group("__gd2"):destroy()
    end)
    it("double destroy is safe", function(): ()
        local g = Lync.group("__gd3"); g:destroy(); g:destroy()
    end)
end)

describe("Group: duplicate name errors", function(): ()
    it("throws", function(): ()
        local g = Lync.group("__gdup")
        expect(function(): () Lync.group("__gdup") end):toThrow("already exists")
        g:destroy()
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Registry = require(script.Parent.Parent.Parent.internal.Registry)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Namespace.define", function(): ()
    it("creates with packets", function(): ()
        expect(Lync.defineNamespace("__ns01", { packets = { hp = { value = Lync.u8 } } })):toBeTruthy()
    end)
    it("creates empty", function(): ()
        expect(Lync.defineNamespace("__ns02", {})):toBeTruthy()
    end)
    it("prefixes names", function(): ()
        Lync.defineNamespace("__ns03", { packets = { dmg = { value = Lync.u8 } } })
        expect(Registry.getByName("__ns03.dmg")):toBeTruthy()
    end)
end)

describe("Namespace validation", function(): ()
    it("throws empty name", function(): ()
        expect(function(): ()
            Lync.defineNamespace("", {})
        end):toThrow()
    end)
    it("throws duplicate", function(): ()
        Lync.defineNamespace("__ns04", {})
        expect(function(): ()
            Lync.defineNamespace("__ns04", {})
        end):toThrow()
    end)
end)

describe("Namespace disconnectAll", function(): ()
    it("safe on empty", function(): ()
        Lync.defineNamespace("__ns05", { packets = { x = { value = Lync.u8 } } }):disconnectAll()
    end)
end)

describe("Namespace sub-tables", function(): ()
    it("packets sub-table has short-name access", function(): ()
        local ns = Lync.defineNamespace("__ns06", { packets = { hp = { value = Lync.u8 } } })
        expect(ns.packets):toBeTruthy()
        expect(ns.packets.hp):toBeTruthy()
        expect(ns.packets.hp):toBe(ns.hp)
    end)
    it("queries sub-table has short-name access", function(): ()
        local ns = Lync.defineNamespace("__ns07", {
            queries = { ping = { request = Lync.nothing, response = Lync.f32 } },
        })
        expect(ns.queries):toBeTruthy()
        expect(ns.queries.ping):toBeTruthy()
        expect(ns.queries.ping):toBe(ns.ping)
    end)
    it("sub-tables are frozen", function(): ()
        local ns = Lync.defineNamespace("__ns08", { packets = { a = { value = Lync.u8 } } })
        expect(table.isfrozen(ns.packets)):toBe(true)
        expect(table.isfrozen(ns.queries)):toBe(true)
    end)
    it("empty sub-tables when none defined", function(): ()
        local ns = Lync.defineNamespace("__ns09", {})
        expect(next(ns.packets)):toBeNil()
        expect(next(ns.queries)):toBeNil()
    end)
end)

return nil

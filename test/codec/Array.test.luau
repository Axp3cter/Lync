--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("array basic", function(): ()
    it("empty = 1 byte", function(): ()
        local r, w = roundTrip(Lync.array(Lync.int(0, 255)), {})
        expect(#r):toBe(0)
        expect(w):toBe(1)
    end)
    it("single element", function(): ()
        local r = roundTrip(Lync.array(Lync.int(0, 255)), { 42 })
        expect(r[1]):toBe(42)
    end)
    it("3 u8 values", function(): ()
        local r = roundTrip(Lync.array(Lync.int(0, 255)), { 10, 20, 30 })
        expect(r[1]):toBe(10)
        expect(r[2]):toBe(20)
        expect(r[3]):toBe(30)
    end)
    it("50 elements", function(): ()
        local data = table.create(50)
        for i = 1, 50 do
            data[i] = i
        end
        local r = roundTrip(Lync.array(Lync.int(0, 255)), data)
        expect(r[1]):toBe(1)
        expect(r[25]):toBe(25)
        expect(r[50]):toBe(50)
    end)
    it("string elements", function(): ()
        local r = roundTrip(Lync.array(Lync.string), { "hello", "world", "foo" })
        expect(r[1]):toBe("hello")
        expect(r[2]):toBe("world")
        expect(r[3]):toBe("foo")
    end)
    it("struct elements", function(): ()
        local elem = Lync.struct({ x = Lync.int(0, 255), y = Lync.int(0, 255) })
        local r = roundTrip(Lync.array(elem), { { x = 1, y = 2 }, { x = 3, y = 4 } })
        expect(r[1].x):toBe(1)
        expect(r[2].y):toBe(4)
    end)
    it("nested arrays", function(): ()
        local inner = Lync.array(Lync.int(0, 255))
        local r = roundTrip(Lync.array(inner), { { 1, 2 }, { 3, 4, 5 } })
        expect(r[1][1]):toBe(1)
        expect(r[1][2]):toBe(2)
        expect(r[2][3]):toBe(5)
    end)
end)

describe("array bool bitpacking", function(): ()
    it("8 bools = 2 bytes (1 count + 1 packed)", function(): ()
        local input = { true, false, true, true, false, false, true, false }
        local r, w = roundTrip(Lync.array(Lync.bool), input)
        expect(w):toBe(2)
        expect(r[1]):toBe(true)
        expect(r[2]):toBe(false)
        expect(r[7]):toBe(true)
    end)
    it("9 bools = 3 bytes", function(): ()
        local input = table.create(9)
        for i = 1, 9 do
            input[i] = i % 2 == 0
        end
        local _, w = roundTrip(Lync.array(Lync.bool), input)
        expect(w):toBe(3)
    end)
    it("16 bools = 3 bytes", function(): ()
        local input = table.create(16)
        for i = 1, 16 do
            input[i] = i % 3 == 0
        end
        local r, w = roundTrip(Lync.array(Lync.bool), input)
        expect(w):toBe(3)
        expect(r[3]):toBe(true)
        expect(r[4]):toBe(false)
    end)
    it("empty bool array", function(): ()
        local r, w = roundTrip(Lync.array(Lync.bool), {})
        expect(#r):toBe(0)
        expect(w):toBe(1)
    end)
    it("single bool", function(): ()
        local r = roundTrip(Lync.array(Lync.bool), { true })
        expect(r[1]):toBe(true)
    end)
end)

describe("array direct path", function(): ()
    it("u16 array", function(): ()
        local r = roundTrip(Lync.array(Lync.int(0, 65535)), { 1000, 2000, 3000 })
        expect(r[1]):toBe(1000)
        expect(r[3]):toBe(3000)
    end)
    it("f32 array", function(): ()
        local r = roundTrip(Lync.array(Lync.f32), { 1.5, 2.5 })
        expect(r[1]):toBeCloseTo(1.5)
        expect(r[2]):toBeCloseTo(2.5)
    end)
end)

describe("array maxCount", function(): ()
    it("accepts within limit", function(): ()
        local r = roundTrip(Lync.array(Lync.int(0, 255), 5), { 1, 2, 3 })
        expect(#r):toBe(3)
    end)
    it("rejects exceeding limit on read", function(): ()
        local ch = Channel.create()
        Lync.array(Lync.int(0, 255)).write(ch, { 1, 2, 3, 4, 5 })
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        expect(function(): ()
            Lync.array(Lync.int(0, 255), 3).read(buf, 0, nil)
        end):toThrow("exceeds max")
    end)
end)

describe("deltaArray", function(): ()
    it("identical = 1 byte", function(): ()
        local c = Lync.deltaArray(Lync.int(0, 255))
        local ch = Channel.create()
        c.write(ch, { 10, 20, 30 })
        ch.cursor = 0
        c.write(ch, { 10, 20, 30 })
        expect(ch.cursor):toBe(1)
    end)
    it("changed triggers larger write", function(): ()
        local c = Lync.deltaArray(Lync.int(0, 255))
        local ch = Channel.create()
        c.write(ch, { 10, 20, 30 })
        ch.cursor = 0
        c.write(ch, { 10, 99, 30 })
        expect(ch.cursor):toBeGreaterThan(1)
    end)
    it("_isDelta = true", function(): ()
        expect((Lync.deltaArray(Lync.int(0, 255)) :: any)._isDelta):toBe(true)
    end)
end)

return nil

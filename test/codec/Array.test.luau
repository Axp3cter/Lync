--!strict
--!optimize 2
local Baseline = require (script.Parent.Parent.Parent.internal.Baseline)
local Channel = require (script.Parent.Parent.Parent.internal.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("array", function (): ()
    it ("empty", function (): ()
        local c = Lync.array (Lync.u8)
        local r = roundTrip (c, {})
        expect (#r):toBe (0)
    end)
    it ("numbers", function (): ()
        local c = Lync.array (Lync.u8)
        local r = roundTrip (c, { 1, 2, 3, 4, 5 })
        expect (#r):toBe (5)
        expect (r[1]):toBe (1)
        expect (r[5]):toBe (5)
    end)
    it ("strings", function (): ()
        local c = Lync.array (Lync.string)
        local r = roundTrip (c, { "hello", "world" })
        expect (r[1]):toBe ("hello")
        expect (r[2]):toBe ("world")
    end)
    it ("nested arrays", function (): ()
        local c = Lync.array (Lync.array (Lync.u8))
        local r = roundTrip (c, { { 1, 2 }, { 3, 4, 5 } })
        expect (#r):toBe (2)
        expect (#r[1]):toBe (2)
        expect (#r[2]):toBe (3)
    end)
end)

describe ("array maxCount", function (): ()
    it ("accepts within limit", function (): ()
        local c = Lync.array (Lync.u8, 5)
        local r = roundTrip (c, { 1, 2, 3 })
        expect (#r):toBe (3)
    end)
    it ("rejects over limit", function (): ()
        expect (function (): ()
            local c = Lync.array (Lync.u8, 2)
            local ch = Channel.create ()
            c.write (ch, { 1, 2, 3 })
            local buf = buffer.create (ch.cursor)
            buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
            c.read (buf, 0, nil)
        end):toThrow ("exceeds max")
    end)
end)

describe ("deltaArray", function (): ()
    it ("full write then delta", function (): ()
        Baseline.setReadKey (false)
        local c = Lync.deltaArray (Lync.u8)
        local ch = Channel.create ()
        c.write (ch, { 10, 20, 30 })
        local w1 = ch.cursor
        ch.cursor = 0
        c.write (ch, { 10, 20, 30 })
        expect (ch.cursor):toBeLessThan (w1)
    end)
    it ("full round-trip", function (): ()
        Baseline.setReadKey (false)
        local c = Lync.deltaArray (Lync.u8)
        local r = roundTrip (c, { 5, 10, 15 })
        expect (#r):toBe (3)
        expect (r[1]):toBe (5)
        expect (r[3]):toBe (15)
    end)
end)

return nil

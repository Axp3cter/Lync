--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("auto types", function(): ()
    it("nil", function(): ()
        expect(roundTrip(Lync.auto, nil)):toBeNil()
    end)
    it("true", function(): ()
        expect(roundTrip(Lync.auto, true)):toBe(true)
    end)
    it("false", function(): ()
        expect(roundTrip(Lync.auto, false)):toBe(false)
    end)
    it("u8 0", function(): ()
        expect(roundTrip(Lync.auto, 0)):toBe(0)
    end)
    it("u8 255", function(): ()
        expect(roundTrip(Lync.auto, 255)):toBe(255)
    end)
    it("string", function(): ()
        expect(roundTrip(Lync.auto, "hi")):toBe("hi")
    end)
    it("vec2", function(): ()
        local r = roundTrip(Lync.auto, Vector2.new(1, 2))
        expect(r.X):toBeCloseTo(1)
    end)
    it("vec3", function(): ()
        local r = roundTrip(Lync.auto, Vector3.new(1, 2, 3))
        expect(r.X):toBeCloseTo(1)
    end)
    it("color3", function(): ()
        local r = roundTrip(Lync.auto, Color3.new(1, 0, 0))
        expect(r.R):toBeCloseTo(1, 0.01)
    end)
    it("cframe", function(): ()
        local r = roundTrip(Lync.auto, CFrame.new(5, 0, 0))
        expect(r.X):toBeCloseTo(5)
    end)
    it("buffer", function(): ()
        local b = buffer.create(4)
        buffer.writeu32(b, 0, 42)
        local r = roundTrip(Lync.auto, b)
        expect(buffer.readu32(r, 0)):toBe(42)
    end)
end)

describe("auto extended types", function(): ()
    it("udim", function(): ()
        local r = roundTrip(Lync.auto, UDim.new(0.5, 10))
        expect(r.Scale):toBeCloseTo(0.5)
    end)
    it("udim2", function(): ()
        local r = roundTrip(Lync.auto, UDim2.new(UDim.new(0.5, 10), UDim.new(1, 20)))
        expect(r.X.Scale):toBeCloseTo(0.5)
    end)
    it("numberRange", function(): ()
        local r = roundTrip(Lync.auto, NumberRange.new(0, 100))
        expect(r.Max):toBeCloseTo(100)
    end)
    it("rect", function(): ()
        local r = roundTrip(Lync.auto, Rect.new(10, 20, 30, 40))
        expect(r.Min.X):toBeCloseTo(10)
    end)
    it("vec2int16", function(): ()
        local r = roundTrip(Lync.auto, Vector2int16.new(100, -200))
        expect(r.X):toBe(100)
    end)
    it("vec3int16", function(): ()
        local r = roundTrip(Lync.auto, Vector3int16.new(1, 2, 3))
        expect(r.Y):toBe(2)
    end)
    it("region3int16", function(): ()
        local r = roundTrip(
            Lync.auto,
            Region3int16.new(Vector3int16.new(0, 0, 0), Vector3int16.new(10, 10, 10))
        )
        expect(r.Max.X):toBe(10)
    end)
    it("ray", function(): ()
        local r = roundTrip(Lync.auto, Ray.new(Vector3.one, Vector3.yAxis))
        expect(r.Origin.X):toBeCloseTo(1)
    end)
end)

describe("auto wire sizes", function(): ()
    it("nil = 1", function(): ()
        local _, w = roundTrip(Lync.auto, nil)
        expect(w):toBe(1)
    end)
    it("bool = 2", function(): ()
        local _, w = roundTrip(Lync.auto, true)
        expect(w):toBe(2)
    end)
    it("u8 = 2", function(): ()
        local _, w = roundTrip(Lync.auto, 0)
        expect(w):toBe(2)
    end)
    it("f32 = 5", function(): ()
        local _, w = roundTrip(Lync.auto, 1.5)
        expect(w):toBe(5)
    end)
    it("vec3 = 13", function(): ()
        local _, w = roundTrip(Lync.auto, Vector3.one)
        expect(w):toBe(13)
    end)
end)

describe("auto number tag selection", function(): ()
    it("small int = u8 tag", function(): ()
        local ch = Channel.create()
        Lync.auto.write(ch, 42)
        local tag = buffer.readu8(ch.buff, 0)
        expect(tag):toBe(2) -- TAG_U8
    end)
    it("256 = u16 tag", function(): ()
        local ch = Channel.create()
        Lync.auto.write(ch, 256)
        expect(buffer.readu8(ch.buff, 0)):toBe(3) -- TAG_U16
    end)
    it("float = f32 tag", function(): ()
        local ch = Channel.create()
        Lync.auto.write(ch, 1.5)
        expect(buffer.readu8(ch.buff, 0)):toBe(8) -- TAG_F32
    end)
    it("negative = i8 tag", function(): ()
        local ch = Channel.create()
        Lync.auto.write(ch, -1)
        expect(buffer.readu8(ch.buff, 0)):toBe(5) -- TAG_I8
    end)
end)

describe("auto errors", function(): ()
    it("throws on function", function(): ()
        expect(function(): ()
            local ch = Channel.create()
            Lync.auto.write(ch, function() end)
        end):toThrow("unsupported type")
    end)
end)

describe("auto region3", function(): ()
    it("round-trips", function(): ()
        local r = roundTrip(Lync.auto, Region3.new(Vector3.new(-5, -5, -5), Vector3.new(5, 5, 5)))
        expect(r.Size.X):toBeCloseTo(10, 0.1)
    end)
end)

describe("auto numberSequence", function(): ()
    it("round-trips", function(): ()
        local seq = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        })
        local r = roundTrip(Lync.auto, seq)
        expect(#r.Keypoints):toBe(2)
    end)
end)

describe("auto colorSequence", function(): ()
    it("round-trips", function(): ()
        local seq = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(1, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.new(0, 0, 1)),
        })
        local r = roundTrip(Lync.auto, seq)
        expect(#r.Keypoints):toBe(2)
    end)
end)

describe("auto f64 needed", function(): ()
    it("large integer = f64", function(): ()
        local r = roundTrip(Lync.auto, 2 ^ 53)
        expect(r):toBe(2 ^ 53)
    end)
    it("irrational = f64 if not f32-exact", function(): ()
        local r = roundTrip(Lync.auto, math.pi)
        expect(r):toBe(math.pi)
    end)
end)

return nil

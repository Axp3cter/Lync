--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("auto: nil", function(): ()
    it("nil = 1 byte", function(): ()
        local r, w = roundTrip(Lync.auto, nil)
        expect(r):toBeNil()
        expect(w):toBe(1)
    end)
end)

describe("auto: booleans", function(): ()
    it("true = 2 bytes", function(): ()
        local r, w = roundTrip(Lync.auto, true)
        expect(r):toBe(true)
        expect(w):toBe(2)
    end)
    it("false = 2 bytes", function(): ()
        local r, w = roundTrip(Lync.auto, false)
        expect(r):toBe(false)
        expect(w):toBe(2)
    end)
end)

describe("auto: integers select smallest wire type", function(): ()
    it("0 = u8 (2 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, 0)
        expect(r):toBe(0)
        expect(w):toBe(2)
    end)
    it("255 = u8 (2 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, 255)
        expect(r):toBe(255)
        expect(w):toBe(2)
    end)
    it("256 = u16 (3 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, 256)
        expect(r):toBe(256)
        expect(w):toBe(3)
    end)
    it("65535 = u16 (3 bytes)", function(): ()
        local _, w = roundTrip(Lync.auto, 65535)
        expect(w):toBe(3)
    end)
    it("65536 = u32 (5 bytes)", function(): ()
        local _, w = roundTrip(Lync.auto, 65536)
        expect(w):toBe(5)
    end)
    it("-1 = i8 (2 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, -1)
        expect(r):toBe(-1)
        expect(w):toBe(2)
    end)
    it("-128 = i8 (2 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, -128)
        expect(r):toBe(-128)
        expect(w):toBe(2)
    end)
    it("-129 = i16 (3 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, -129)
        expect(r):toBe(-129)
        expect(w):toBe(3)
    end)
    it("-32768 = i16 (3 bytes)", function(): ()
        local _, w = roundTrip(Lync.auto, -32768)
        expect(w):toBe(3)
    end)
    it("-32769 = i32 (5 bytes)", function(): ()
        local r, w = roundTrip(Lync.auto, -32769)
        expect(r):toBe(-32769)
        expect(w):toBe(5)
    end)
end)

describe("auto: floats", function(): ()
    it("f32 representable = 5 bytes", function(): ()
        local r, w = roundTrip(Lync.auto, 1.5)
        expect(r):toBeCloseTo(1.5)
        expect(w):toBe(5)
    end)
    it("f64 needed = 9 bytes", function(): ()
        local v = math.pi
        local r, w = roundTrip(Lync.auto, v)
        expect(r):toBeCloseTo(v, 1e-14)
        expect(w):toBe(9)
    end)
end)

describe("auto: strings", function(): ()
    it("empty string", function(): ()
        local r = roundTrip(Lync.auto, "")
        expect(r):toBe("")
    end)
    it("short string", function(): ()
        local r = roundTrip(Lync.auto, "hello")
        expect(r):toBe("hello")
    end)
    it("long string", function(): ()
        local s = string.rep("x", 300)
        expect(roundTrip(Lync.auto, s)):toBe(s)
    end)
end)

describe("auto: Roblox types", function(): ()
    it("Vector2", function(): ()
        local r = roundTrip(Lync.auto, Vector2.new(1, 2))
        expect(r.X):toBeCloseTo(1)
        expect(r.Y):toBeCloseTo(2)
    end)
    it("Vector3", function(): ()
        local r = roundTrip(Lync.auto, Vector3.new(1, 2, 3))
        expect(r.X):toBeCloseTo(1)
        expect(r.Z):toBeCloseTo(3)
    end)
    it("Color3", function(): ()
        local r = roundTrip(Lync.auto, Color3.fromRGB(255, 128, 0))
        expect(r.R):toBeCloseTo(1, 0.01)
    end)
    it("CFrame", function(): ()
        local r = roundTrip(Lync.auto, CFrame.new(10, 20, 30))
        expect(r.Position.X):toBeCloseTo(10)
    end)
    it("UDim", function(): ()
        local r = roundTrip(Lync.auto, UDim.new(0.5, 10))
        expect(r.Scale):toBeCloseTo(0.5)
    end)
    it("UDim2", function(): ()
        local r = roundTrip(Lync.auto, UDim2.new(UDim.new(1, 0), UDim.new(0, 50)))
        expect(r.X.Scale):toBeCloseTo(1)
    end)
    it("NumberRange", function(): ()
        local r = roundTrip(Lync.auto, NumberRange.new(5, 10))
        expect(r.Min):toBeCloseTo(5)
    end)
    it("Rect", function(): ()
        local r = roundTrip(Lync.auto, Rect.new(0, 0, 100, 100))
        expect(r.Max.X):toBeCloseTo(100)
    end)
    it("Ray", function(): ()
        local r = roundTrip(Lync.auto, Ray.new(Vector3.zero, Vector3.yAxis))
        expect(r.Direction.Y):toBeCloseTo(1)
    end)
    it("Vector2int16", function(): ()
        local r = roundTrip(Lync.auto, Vector2int16.new(10, -20))
        expect(r.X):toBe(10)
        expect(r.Y):toBe(-20)
    end)
    it("Vector3int16", function(): ()
        local r = roundTrip(Lync.auto, Vector3int16.new(1, 2, 3))
        expect(r.X):toBe(1)
        expect(r.Z):toBe(3)
    end)
end)

describe("auto: errors on unsupported", function(): ()
    it("table errors", function(): ()
        local Channel = require(script.Parent.Parent.Parent.internal.Channel)
        expect(function(): ()
            Lync.auto.write(Channel.create(), { 1, 2, 3 })
        end):toThrow("unsupported")
    end)
end)

return nil

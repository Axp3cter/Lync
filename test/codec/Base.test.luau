--!strict
--!optimize 2
local Base = require(script.Parent.Parent.Parent.codec.Base)
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Base.define", function(): ()
    it("creates codec with _size", function(): ()
        local c = Base.define(4, function(b, o, v)
            buffer.writeu32(b, o, v)
        end, function(b, o)
            return buffer.readu32(b, o)
        end)
        expect((c :: any)._size):toBe(4)
    end)
    it("write allocates and advances", function(): ()
        local c = Base.define(2, function(b, o, v)
            buffer.writeu16(b, o, v)
        end, function(b, o)
            return buffer.readu16(b, o)
        end)
        local ch = Channel.create()
        c.write(ch, 1000)
        expect(ch.cursor):toBe(2)
    end)
    it("read returns value and size", function(): ()
        local c = Base.define(2, function(b, o, v)
            buffer.writeu16(b, o, v)
        end, function(b, o)
            return buffer.readu16(b, o)
        end)
        local buf = buffer.create(2)
        buffer.writeu16(buf, 0, 1234)
        local val, consumed = c.read(buf, 0, nil)
        expect(val):toBe(1234)
        expect(consumed):toBe(2)
    end)
    it("_directWrite and _directRead exposed", function(): ()
        local dw = function(b: buffer, o: number, v: number)
            buffer.writeu8(b, o, v)
        end
        local dr = function(b: buffer, o: number)
            return buffer.readu8(b, o)
        end
        local c = Base.define(1, dw, dr) :: any
        expect(c._directWrite):toBe(dw)
        expect(c._directRead):toBe(dr)
    end)
end)

describe("Base.zero", function(): ()
    it("_size = 0", function(): ()
        local c = Base.zero()
        expect((c :: any)._size):toBe(0)
    end)
    it("write is no-op", function(): ()
        local c = Base.zero()
        local ch = Channel.create()
        c.write(ch, "anything")
        expect(ch.cursor):toBe(0)
    end)
    it("read returns nil, 0", function(): ()
        local c = Base.zero()
        local val, consumed = c.read(buffer.create(0), 0, nil)
        expect(val):toBeNil()
        expect(consumed):toBe(0)
    end)
end)

return nil

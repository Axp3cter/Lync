--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Buffer round-trip", function (): ()
    it ("empty buffer", function (): ()
        local r = roundTrip (Lync.buff, buffer.create (0))
        expect (buffer.len (r)):toBe (0)
    end)
    it ("1-byte buffer", function (): ()
        local inp = buffer.create (1)
        buffer.writeu8 (inp, 0, 0xAB)
        local r = roundTrip (Lync.buff, inp)
        expect (buffer.len (r)):toBe (1)
        expect (buffer.readu8 (r, 0)):toBe (0xAB)
    end)
    it ("4-byte buffer", function (): ()
        local inp = buffer.create (4)
        buffer.writeu32 (inp, 0, 0xDEADBEEF)
        local r = roundTrip (Lync.buff, inp)
        expect (buffer.len (r)):toBe (4)
        expect (buffer.readu32 (r, 0)):toBe (0xDEADBEEF)
    end)
    it ("1KB buffer preserves all bytes", function (): ()
        local inp = buffer.create (1024)
        for i = 0, 255 do
            buffer.writeu8 (inp, i, i)
        end
        local r = roundTrip (Lync.buff, inp)
        expect (buffer.len (r)):toBe (1024)
        for i = 0, 255 do
            expect (buffer.readu8 (r, i)):toBe (i)
        end
    end)
    it ("all-zero buffer", function (): ()
        local inp = buffer.create (64)
        local r = roundTrip (Lync.buff, inp)
        expect (buffer.len (r)):toBe (64)
        for i = 0, 63 do
            expect (buffer.readu8 (r, i)):toBe (0)
        end
    end)
    it ("128-byte buffer (2-byte varint)", function (): ()
        local inp = buffer.create (128)
        buffer.writeu8 (inp, 0, 0xFF)
        buffer.writeu8 (inp, 127, 0xAA)
        local r = roundTrip (Lync.buff, inp)
        expect (buffer.len (r)):toBe (128)
        expect (buffer.readu8 (r, 0)):toBe (0xFF)
        expect (buffer.readu8 (r, 127)):toBe (0xAA)
    end)
end)

describe ("Buffer wire size", function (): ()
    it ("empty = 1 byte varint", function (): ()
        local _, w = roundTrip (Lync.buff, buffer.create (0))
        expect (w):toBe (1)
    end)
    it ("4 bytes = 5 (1 varint + 4)", function (): ()
        local _, w = roundTrip (Lync.buff, buffer.create (4))
        expect (w):toBe (5)
    end)
    it ("128 bytes = 130 (2 varint + 128)", function (): ()
        local _, w = roundTrip (Lync.buff, buffer.create (128))
        expect (w):toBe (130)
    end)
    it ("no _size (variable length)", function (): ()
        expect ((Lync.buff :: any)._size):toBeNil ()
    end)
end)

return nil

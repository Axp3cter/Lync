--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Buffer codec", function(): ()
    it("empty buffer = 1 byte", function(): ()
        local ch = Channel.create()
        Lync.buff.write(ch, buffer.create(0))
        expect(ch.cursor):toBe(1)
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        local r, c = Lync.buff.read(buf, 0, nil)
        expect(buffer.len(r)):toBe(0)
        expect(c):toBe(1)
    end)
    it("4 bytes inline", function(): ()
        local ch = Channel.create()
        local input = buffer.create(4)
        buffer.writeu32(input, 0, 0xDEADBEEF)
        Lync.buff.write(ch, input)
        expect(ch.cursor):toBe(5)
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        local r, _ = Lync.buff.read(buf, 0, nil)
        expect(buffer.readu32(r, 0)):toBe(0xDEADBEEF)
    end)
    it("100 bytes round-trip", function(): ()
        local ch = Channel.create()
        local input = buffer.create(100)
        for i = 0, 99 do
            buffer.writeu8(input, i, i)
        end
        Lync.buff.write(ch, input)
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        local r, _ = Lync.buff.read(buf, 0, nil)
        expect(buffer.len(r)):toBe(100)
        expect(buffer.readu8(r, 0)):toBe(0)
        expect(buffer.readu8(r, 99)):toBe(99)
    end)
    it("191 bytes = inline threshold", function(): ()
        local ch = Channel.create()
        Lync.buff.write(ch, buffer.create(191))
        expect(ch.cursor):toBe(192)
    end)
    it("192 bytes uses varint prefix", function(): ()
        local ch = Channel.create()
        Lync.buff.write(ch, buffer.create(192))
        expect(ch.cursor):toBe(194)
    end)
    it("read creates isolated copy", function(): ()
        local ch = Channel.create()
        local input = buffer.create(4)
        buffer.writeu32(input, 0, 0xCAFE)
        Lync.buff.write(ch, input)
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        local r1, _ = Lync.buff.read(buf, 0, nil)
        local r2, _ = Lync.buff.read(buf, 0, nil)
        buffer.writeu32(r1, 0, 0)
        expect(buffer.readu32(r2, 0)):toBe(0xCAFE)
    end)
    it("_typeCheck = buffer", function(): ()
        expect((Lync.buff :: any)._typeCheck):toBe("buffer")
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("cframe lossless (24 bytes)", function(): ()
    it("_size = 24", function(): () expect((Lync.cframe :: any)._size):toBe(24) end)
    it("identity", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(0, 0, 0))
        expect(r.Position.X):toBeCloseTo(0); expect(r.Position.Y):toBeCloseTo(0); expect(r.Position.Z):toBeCloseTo(0)
    end)
    it("position only", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(10, 20, 30))
        expect(r.Position.X):toBeCloseTo(10); expect(r.Position.Y):toBeCloseTo(20); expect(r.Position.Z):toBeCloseTo(30)
    end)
    it("negative position", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(-5, -10, -15))
        expect(r.Position.X):toBeCloseTo(-5); expect(r.Position.Y):toBeCloseTo(-10)
    end)
    it("position + rotation", function(): ()
        local cf = CFrame.new(10, 20, 30) * CFrame.Angles(0.5, 1.0, 0.3)
        local r = roundTrip(Lync.cframe, cf)
        expect(r.Position.X):toBeCloseTo(10, 0.001); expect(r.Position.Y):toBeCloseTo(20, 0.001)
    end)
    it("90 degree rotation", function(): ()
        local cf = CFrame.new(0, 0, 0) * CFrame.Angles(math.pi / 2, 0, 0)
        local r = roundTrip(Lync.cframe, cf)
        local rx, _, _ = r:ToEulerAnglesXYZ()
        expect(rx):toBeCloseTo(math.pi / 2, 0.001)
    end)
    it("45 degree rotation", function(): ()
        local cf = CFrame.new(0, 0, 0) * CFrame.Angles(0, math.pi / 4, 0)
        local r = roundTrip(Lync.cframe, cf)
        local _, ry, _ = r:ToEulerAnglesXYZ()
        expect(ry):toBeCloseTo(math.pi / 4, 0.001)
    end)
    it("wire = 24 bytes", function(): () local _, w = roundTrip(Lync.cframe, CFrame.new(1, 2, 3)); expect(w):toBe(24) end)
    it("_typeCheck = CFrame", function(): () expect((Lync.cframe :: any)._typeCheck):toBe("CFrame") end)
end)

describe("cframe compressed via __call (16 bytes)", function(): ()
    it("_size = 16", function(): () expect((Lync.cframe() :: any)._size):toBe(16) end)
    it("saves 8 bytes vs lossless", function(): ()
        expect((Lync.cframe :: any)._size - (Lync.cframe() :: any)._size):toBe(8)
    end)
    it("identity position", function(): ()
        local r = roundTrip(Lync.cframe(), CFrame.new(5, 10, 15))
        expect(r.Position.X):toBeCloseTo(5, 0.001); expect(r.Position.Y):toBeCloseTo(10, 0.001)
    end)
    it("rotation precision < 0.003 radians (~0.16 degrees)", function(): ()
        local cf = CFrame.new(0, 0, 0) * CFrame.Angles(1.0, 0.5, 0.3)
        local r = roundTrip(Lync.cframe(), cf)
        local ox, oy, oz = cf:ToEulerAnglesXYZ()
        local rx, ry, rz = r:ToEulerAnglesXYZ()
        expect(rx):toBeCloseTo(ox, 0.003); expect(ry):toBeCloseTo(oy, 0.003); expect(rz):toBeCloseTo(oz, 0.003)
    end)
    it("X-dominant quaternion", function(): ()
        local r = roundTrip(Lync.cframe(), CFrame.new(1, 2, 3) * CFrame.Angles(2.5, 0, 0))
        expect(r.Position.X):toBeCloseTo(1, 0.001)
    end)
    it("Y-dominant quaternion", function(): ()
        local r = roundTrip(Lync.cframe(), CFrame.new(1, 2, 3) * CFrame.Angles(0, 2.5, 0))
        expect(r.Position.X):toBeCloseTo(1, 0.001)
    end)
    it("Z-dominant quaternion", function(): ()
        local r = roundTrip(Lync.cframe(), CFrame.new(1, 2, 3) * CFrame.Angles(0, 0, 2.5))
        expect(r.Position.X):toBeCloseTo(1, 0.001)
    end)
    it("W-dominant quaternion (near identity)", function(): ()
        local r = roundTrip(Lync.cframe(), CFrame.new(1, 2, 3) * CFrame.Angles(0.1, 0.1, 0.1))
        expect(r.Position.X):toBeCloseTo(1, 0.001)
    end)
    it("90 degree rotation", function(): ()
        local cf = CFrame.new(0, 5, 0) * CFrame.Angles(math.pi / 2, 0, 0)
        local r = roundTrip(Lync.cframe(), cf)
        expect(r.Position.Y):toBeCloseTo(5, 0.001)
    end)
    it("negative rotation", function(): ()
        local cf = CFrame.new(0, 0, 0) * CFrame.Angles(-1, -0.5, -0.3)
        local r = roundTrip(Lync.cframe(), cf)
        local ox, _, _ = cf:ToEulerAnglesXYZ()
        local rx, _, _ = r:ToEulerAnglesXYZ()
        expect(rx):toBeCloseTo(ox, 0.003)
    end)
    it("_typeCheck = CFrame", function(): () expect((Lync.cframe() :: any)._typeCheck):toBe("CFrame") end)
end)

return nil

--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("cframe position", function (): ()
    it ("identity", function (): ()
        local r = roundTrip (Lync.cframe, CFrame.identity)
        expect (r.X):toBeCloseTo (0)
        expect (r.Y):toBeCloseTo (0)
        expect (r.Z):toBeCloseTo (0)
    end)
    it ("translated", function (): ()
        local r = roundTrip (Lync.cframe, CFrame.new (10, 20, 30))
        expect (r.X):toBeCloseTo (10)
        expect (r.Y):toBeCloseTo (20)
        expect (r.Z):toBeCloseTo (30)
    end)
    it ("negative", function (): ()
        local r = roundTrip (Lync.cframe, CFrame.new (-100, -200, -300))
        expect (r.X):toBeCloseTo (-100)
        expect (r.Y):toBeCloseTo (-200)
        expect (r.Z):toBeCloseTo (-300)
    end)
    it ("24 bytes", function (): ()
        local _, w = roundTrip (Lync.cframe, CFrame.identity)
        expect (w):toBe (24)
    end)
end)

describe ("cframe rotation", function (): ()
    it ("90 degrees Y", function (): ()
        local cf = CFrame.Angles (0, math.pi / 2, 0)
        local r = roundTrip (Lync.cframe, cf)
        local _, angle = r:ToAxisAngle ()
        expect (angle):toBeCloseTo (math.pi / 2, 0.01)
    end)
    it ("45 degrees X", function (): ()
        local cf = CFrame.Angles (math.pi / 4, 0, 0)
        local r = roundTrip (Lync.cframe, cf)
        local _, angle = r:ToAxisAngle ()
        expect (angle):toBeCloseTo (math.pi / 4, 0.01)
    end)
    it ("arbitrary rotation preserves LookVector", function (): ()
        local cf = CFrame.new (5, 10, 15) * CFrame.Angles (0.3, 0.7, 1.1)
        local r = roundTrip (Lync.cframe, cf)
        expect (r.LookVector.X):toBeCloseTo (cf.LookVector.X, 0.001)
        expect (r.LookVector.Y):toBeCloseTo (cf.LookVector.Y, 0.001)
        expect (r.LookVector.Z):toBeCloseTo (cf.LookVector.Z, 0.001)
    end)
    it ("lookAt", function (): ()
        local cf = CFrame.lookAt (Vector3.new (0, 10, 0), Vector3.new (5, 0, 5))
        local r = roundTrip (Lync.cframe, cf)
        expect (r.Position.X):toBeCloseTo (0, 0.01)
        expect (r.Position.Y):toBeCloseTo (10, 0.01)
        expect (r.LookVector.X):toBeCloseTo (cf.LookVector.X, 0.01)
        expect (r.LookVector.Z):toBeCloseTo (cf.LookVector.Z, 0.01)
    end)
    it ("180 degrees", function (): ()
        local cf = CFrame.Angles (0, math.pi, 0)
        local r = roundTrip (Lync.cframe, cf)
        expect (r.LookVector.Z):toBeCloseTo (cf.LookVector.Z, 0.01)
    end)
    it ("identity rotation preserved", function (): ()
        local r = roundTrip (Lync.cframe, CFrame.identity)
        expect (r.LookVector.Z):toBeCloseTo (-1, 0.001)
    end)
    it ("position + rotation combined", function (): ()
        local cf = CFrame.new (100, -50, 200) * CFrame.Angles (1, 2, 3)
        local r = roundTrip (Lync.cframe, cf)
        expect (r.X):toBeCloseTo (100, 0.01)
        expect (r.Y):toBeCloseTo (-50, 0.01)
        expect (r.Z):toBeCloseTo (200, 0.01)
        expect (r.UpVector.X):toBeCloseTo (cf.UpVector.X, 0.01)
        expect (r.UpVector.Y):toBeCloseTo (cf.UpVector.Y, 0.01)
    end)
end)

return nil

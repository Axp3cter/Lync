--!strict
--!optimize 2
local Runner  = require(script.Parent.Parent.Runner)
local Channel = require(script.Parent.Parent.Parent.core.Channel)
local Lync    = require(script.Parent.Parent.Parent)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("CFrame round-trip", function(): ()
    it("identity", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new())
        expect(r.Position.X):toBe(0); expect(r.Position.Y):toBe(0); expect(r.Position.Z):toBe(0)
    end)
    it("translation only", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(10, 20, 30))
        expect(r.Position.X):toBeCloseTo(10); expect(r.Position.Y):toBeCloseTo(20); expect(r.Position.Z):toBeCloseTo(30)
    end)
    it("negative position", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(-100, -200, -300))
        expect(r.Position.X):toBeCloseTo(-100); expect(r.Position.Y):toBeCloseTo(-200); expect(r.Position.Z):toBeCloseTo(-300)
    end)
    it("rotated 45° around Y", function(): ()
        local orig = CFrame.new(5, 10, 15) * CFrame.Angles(0, math.pi/4, 0)
        local r = roundTrip(Lync.cframe, orig)
        expect(r.Position.X):toBeCloseTo(orig.Position.X, 0.01)
        local _, angle = r:ToAxisAngle()
        expect(angle):toBeCloseTo(math.pi/4, 0.01)
    end)
    it("rotated 180° around Y", function(): ()
        local orig = CFrame.Angles(0, math.pi, 0)
        local r = roundTrip(Lync.cframe, orig)
        local _, angle = r:ToAxisAngle()
        expect(angle):toBeCloseTo(math.pi, 0.01)
    end)
    it("compound rotation (all 3 axes)", function(): ()
        local orig = CFrame.new(1, 2, 3) * CFrame.Angles(0.5, 1.0, 1.5)
        local r = roundTrip(Lync.cframe, orig)
        expect(r.Position.X):toBeCloseTo(1, 0.01)
        expect(r.Position.Y):toBeCloseTo(2, 0.01)
        expect(r.Position.Z):toBeCloseTo(3, 0.01)
    end)
    it("very small rotation near epsilon", function(): ()
        local orig = CFrame.new(0, 0, 0) * CFrame.Angles(1e-8, 0, 0)
        local r = roundTrip(Lync.cframe, orig)
        -- Should not crash, rotation is near-zero so effectively identity
        expect(r.Position.X):toBeCloseTo(0)
    end)
    it("large position values", function(): ()
        local r = roundTrip(Lync.cframe, CFrame.new(1e6, -1e6, 5e5))
        expect(r.Position.X):toBeCloseTo(1e6, 100)
        expect(r.Position.Y):toBeCloseTo(-1e6, 100)
    end)
end)

describe("CFrame identity axis zeroing", function(): ()
    it("axis bytes are zero at identity", function(): ()
        local ch = Channel.create()
        Lync.cframe.write(ch, CFrame.new(1, 2, 3))
        expect(buffer.readf32(ch.buff, 12)):toBe(0)
        expect(buffer.readf32(ch.buff, 16)):toBe(0)
        expect(buffer.readf32(ch.buff, 20)):toBe(0)
    end)
    it("deterministic across writes", function(): ()
        local ch1, ch2 = Channel.create(), Channel.create()
        Lync.cframe.write(ch1, CFrame.new(5, 5, 5))
        Lync.cframe.write(ch2, CFrame.new(5, 5, 5))
        for i = 0, 23 do expect(buffer.readu8(ch1.buff, i)):toBe(buffer.readu8(ch2.buff, i)) end
    end)
end)

describe("CFrame wire", function(): ()
    it("uses 24 bytes", function(): () local _, w = roundTrip(Lync.cframe, CFrame.new()); expect(w):toBe(24) end)
    it("_size is 24",   function(): () expect((Lync.cframe :: any)._size):toBe(24) end)
end)

return nil

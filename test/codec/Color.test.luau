--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Color3 round-trip", function (): ()
    it ("black", function (): ()
        local r = roundTrip (Lync.color3, Color3.new (0, 0, 0))
        expect (r.R):toBe (0)
        expect (r.G):toBe (0)
        expect (r.B):toBe (0)
    end)
    it ("white", function (): ()
        local r = roundTrip (Lync.color3, Color3.new (1, 1, 1))
        expect (r.R):toBeCloseTo (1, 0.01)
        expect (r.G):toBeCloseTo (1, 0.01)
        expect (r.B):toBeCloseTo (1, 0.01)
    end)
    it ("pure red", function (): ()
        local r = roundTrip (Lync.color3, Color3.fromRGB (255, 0, 0))
        expect (r.R):toBeCloseTo (1, 0.01)
        expect (r.G):toBe (0)
        expect (r.B):toBe (0)
    end)
    it ("pure green", function (): ()
        local r = roundTrip (Lync.color3, Color3.fromRGB (0, 255, 0))
        expect (r.R):toBe (0)
        expect (r.G):toBeCloseTo (1, 0.01)
        expect (r.B):toBe (0)
    end)
    it ("pure blue", function (): ()
        local r = roundTrip (Lync.color3, Color3.fromRGB (0, 0, 255))
        expect (r.R):toBe (0)
        expect (r.G):toBe (0)
        expect (r.B):toBeCloseTo (1, 0.01)
    end)
    it ("mid-value within 1/255 tolerance", function (): ()
        local orig = Color3.fromRGB (128, 64, 200)
        local r = roundTrip (Lync.color3, orig)
        expect (r.R):toBeCloseTo (orig.R, 1 / 255)
        expect (r.G):toBeCloseTo (orig.G, 1 / 255)
        expect (r.B):toBeCloseTo (orig.B, 1 / 255)
    end)
    it ("every RGB integer round-trips exactly", function (): ()
        for _, v in { 0, 1, 127, 128, 254, 255 } do
            local c = Color3.fromRGB (v, v, v)
            local r = roundTrip (Lync.color3, c)
            local expected = v / 255
            expect (r.R):toBeCloseTo (expected, 1 / 255)
        end
    end)
end)

describe ("Color3 clamping", function (): ()
    it ("clamps R > 1 to 255", function (): ()
        local ch = Channel.create ()
        Lync.color3.write (ch, Color3.new (1.5, 0, 0))
        expect (buffer.readu8 (ch.buff, 0)):toBe (255)
    end)
    it ("clamps R < 0 to 0", function (): ()
        local ch = Channel.create ()
        Lync.color3.write (ch, Color3.new (-0.5, 0, 0))
        expect (buffer.readu8 (ch.buff, 0)):toBe (0)
    end)
end)

describe ("Color3 wire", function (): ()
    it ("uses 3 bytes", function (): ()
        local _, w = roundTrip (Lync.color3, Color3.new ())
        expect (w):toBe (3)
    end)
    it ("_size is 3", function (): ()
        expect ((Lync.color3 :: any)._size):toBe (3)
    end)
    it ("writes R G B in order", function (): ()
        local ch = Channel.create ()
        Lync.color3.write (ch, Color3.fromRGB (10, 20, 30))
        expect (buffer.readu8 (ch.buff, 0)):toBe (10)
        expect (buffer.readu8 (ch.buff, 1)):toBe (20)
        expect (buffer.readu8 (ch.buff, 2)):toBe (30)
    end)
end)

return nil

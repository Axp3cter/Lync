--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("color3", function(): ()
    it("_size = 3", function(): ()
        expect((Lync.color3 :: any)._size):toBe(3)
    end)
    it("pure red", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(255, 0, 0))
        expect(r.R):toBeCloseTo(1, 0.01)
        expect(r.G):toBeCloseTo(0, 0.01)
    end)
    it("pure green", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(0, 255, 0))
        expect(r.G):toBeCloseTo(1, 0.01)
    end)
    it("pure blue", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(0, 0, 255))
        expect(r.B):toBeCloseTo(1, 0.01)
    end)
    it("black", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(0, 0, 0))
        expect(r.R):toBeCloseTo(0, 0.01)
    end)
    it("white", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(255, 255, 255))
        expect(r.R):toBeCloseTo(1, 0.01)
    end)
    it("mid gray", function(): ()
        local r = roundTrip(Lync.color3, Color3.fromRGB(128, 128, 128))
        expect(r.R):toBeCloseTo(128 / 255, 0.01)
    end)
    it("clamps HDR (R > 1)", function(): ()
        expect(roundTrip(Lync.color3, Color3.new(2.0, 0, 0)).R):toBeCloseTo(1.0, 0.01)
    end)
    it("clamps negative", function(): ()
        expect(roundTrip(Lync.color3, Color3.new(-1, 0, 0)).R):toBeCloseTo(0, 0.01)
    end)
    it("_typeCheck = Color3", function(): ()
        expect((Lync.color3 :: any)._typeCheck):toBe("Color3")
    end)
    it("wire = 3 bytes", function(): ()
        local _, w = roundTrip(Lync.color3, Color3.new())
        expect(w):toBe(3)
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("custom", function(): ()
    it("4-byte round-trip", function(): ()
        local c = Lync.custom(4, function(b, o, v)
            buffer.writeu32(b, o, v)
        end, function(b, o)
            return buffer.readu32(b, o)
        end)
        expect((c :: any)._size):toBe(4)
        expect(roundTrip(c, 12345)):toBe(12345)
    end)
    it("1-byte round-trip", function(): ()
        local c = Lync.custom(1, function(b, o, v)
            buffer.writeu8(b, o, v)
        end, function(b, o)
            return buffer.readu8(b, o)
        end)
        expect(roundTrip(c, 42)):toBe(42)
    end)
    it("size 0 returns zero codec", function(): ()
        local c = Lync.custom(0, function() end, function()
            return nil
        end)
        expect((c :: any)._size):toBe(0)
    end)
    it("has _directWrite", function(): ()
        local c = Lync.custom(2, function(b, o, v)
            buffer.writeu16(b, o, v)
        end, function(b, o)
            return buffer.readu16(b, o)
        end)
        expect((c :: any)._directWrite):toBeTruthy()
    end)
    it("rejects negative size", function(): ()
        expect(function(): ()
            Lync.custom(-1, function() end, function() end)
        end):toThrow("non-negative")
    end)
    it("rejects non-integer size", function(): ()
        expect(function(): ()
            Lync.custom(1.5, function() end, function() end)
        end):toThrow("non-negative")
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("f16", function(): ()
    it("_size = 2", function(): ()
        expect((Lync.f16 :: any)._size):toBe(2)
    end)
    it("zero", function(): ()
        expect(roundTrip(Lync.f16, 0)):toBe(0)
    end)
    it("1.0 exactly", function(): ()
        expect(roundTrip(Lync.f16, 1)):toBe(1)
    end)
    it("-1.0", function(): ()
        expect(roundTrip(Lync.f16, -1)):toBe(-1)
    end)
    it("0.5", function(): ()
        expect(roundTrip(Lync.f16, 0.5)):toBeCloseTo(0.5, 0.001)
    end)
    it("0.1 (~3 digit precision)", function(): ()
        expect(roundTrip(Lync.f16, 0.1)):toBeCloseTo(0.1, 0.001)
    end)
    it("max normal 65504", function(): ()
        expect(roundTrip(Lync.f16, 65504)):toBe(65504)
    end)
    it("overflow → inf", function(): ()
        expect(roundTrip(Lync.f16, 100000)):toBe(math.huge)
    end)
    it("-overflow → -inf", function(): ()
        expect(roundTrip(Lync.f16, -100000)):toBe(-math.huge)
    end)
    it("NaN → NaN", function(): ()
        local r = roundTrip(Lync.f16, 0 / 0)
        expect(r ~= r):toBe(true)
    end)
    it("subnormal round-trip", function(): ()
        expect(roundTrip(Lync.f16, 0.00006)):toBeCloseTo(0.00006, 0.00002)
    end)
    it("negative subnormal", function(): ()
        expect(roundTrip(Lync.f16, -0.00006)):toBeCloseTo(-0.00006, 0.00002)
    end)
    it("100.5", function(): ()
        expect(roundTrip(Lync.f16, 100.5)):toBeCloseTo(100.5, 0.1)
    end)
    it("-42.25", function(): ()
        expect(roundTrip(Lync.f16, -42.25)):toBeCloseTo(-42.25, 0.1)
    end)
    it("wire = 2 bytes", function(): ()
        local _, w = roundTrip(Lync.f16, 42)
        expect(w):toBe(2)
    end)
end)

return nil

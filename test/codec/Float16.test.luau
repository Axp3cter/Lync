--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Float16 exact values", function (): ()
    it ("0", function (): ()
        expect (roundTrip (Lync.f16, 0)):toBe (0)
    end)
    it ("1.0", function (): ()
        expect (roundTrip (Lync.f16, 1)):toBe (1)
    end)
    it ("-1.0", function (): ()
        expect (roundTrip (Lync.f16, -1)):toBe (-1)
    end)
    it ("0.5", function (): ()
        expect (roundTrip (Lync.f16, 0.5)):toBe (0.5)
    end)
    it ("-0.5", function (): ()
        expect (roundTrip (Lync.f16, -0.5)):toBe (-0.5)
    end)
    it ("2.0", function (): ()
        expect (roundTrip (Lync.f16, 2)):toBe (2)
    end)
    it ("0.25", function (): ()
        expect (roundTrip (Lync.f16, 0.25)):toBe (0.25)
    end)
    it ("65504 (max half)", function (): ()
        expect (roundTrip (Lync.f16, 65504)):toBe (65504)
    end)
    it ("-65504", function (): ()
        expect (roundTrip (Lync.f16, -65504)):toBe (-65504)
    end)
end)

describe ("Float16 approximate values", function (): ()
    it ("3.14", function (): ()
        expect (roundTrip (Lync.f16, 3.14)):toBeCloseTo (3.14, 0.01)
    end)
    it ("100.5", function (): ()
        expect (roundTrip (Lync.f16, 100.5)):toBeCloseTo (100.5, 0.1)
    end)
    it ("-0.001", function (): ()
        expect (roundTrip (Lync.f16, -0.001)):toBeCloseTo (-0.001, 0.0001)
    end)
end)

describe ("Float16 edge cases", function (): ()
    it ("overflow → inf", function (): ()
        expect (roundTrip (Lync.f16, 100000)):toBe (math.huge)
    end)
    it ("-overflow → -inf", function (): ()
        expect (roundTrip (Lync.f16, -100000)):toBe (-math.huge)
    end)
    it ("-0 → +0", function (): ()
        expect (roundTrip (Lync.f16, -0.0)):toBe (0)
    end)
    it ("NaN → NaN", function (): ()
        local r = roundTrip (Lync.f16, 0 / 0)
        expect (r ~= r):toBe (true)
    end)
    it ("subnormal", function (): ()
        expect (roundTrip (Lync.f16, 0.00006)):toBeCloseTo (0.00006, 0.00004)
    end)
    it ("smallest positive normal", function (): ()
        local r = roundTrip (Lync.f16, 0.00006104)
        expect (r > 0):toBe (true)
        expect (r):toBeCloseTo (0.00006104, 0.0001)
    end)
end)

describe ("Float16 wire", function (): ()
    it ("uses 2 bytes", function (): ()
        local _, w = roundTrip (Lync.f16, 1)
        expect (w):toBe (2)
    end)
    it ("_size is 2", function (): ()
        expect ((Lync.f16 :: any)._size):toBe (2)
    end)
end)

return nil

--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("inst codec", function(): ()
    it("_size = 2", function(): () expect((Lync.inst :: any)._size):toBe(2) end)
    it("_typeCheck = Instance", function(): () expect((Lync.inst :: any)._typeCheck):toBe("Instance") end)
    it("write increments refCount", function(): ()
        local ch = Channel.create()
        local part = Instance.new("Part")
        Lync.inst.write(ch, part)
        expect(ch.refCount):toBe(1)
        expect(ch.refs[1]):toBe(part)
        expect(ch.cursor):toBe(2)
        part:Destroy()
    end)
    it("two instances get separate indices", function(): ()
        local ch = Channel.create()
        local p1 = Instance.new("Part")
        local p2 = Instance.new("Part")
        Lync.inst.write(ch, p1)
        Lync.inst.write(ch, p2)
        expect(ch.refCount):toBe(2)
        expect(ch.refs[1]):toBe(p1); expect(ch.refs[2]):toBe(p2)
        p1:Destroy(); p2:Destroy()
    end)
    it("read requires refs", function(): ()
        local buf = buffer.create(2); buffer.writeu16(buf, 0, 1)
        expect(function(): () Lync.inst.read(buf, 0, nil) end):toThrow("requires refs")
    end)
    it("read rejects out-of-bounds index", function(): ()
        local buf = buffer.create(2); buffer.writeu16(buf, 0, 5)
        expect(function(): () Lync.inst.read(buf, 0, {} :: any) end):toThrow("out of bounds")
    end)
    it("round-trip through refs", function(): ()
        local ch = Channel.create()
        local part = Instance.new("Part")
        Lync.inst.write(ch, part)
        local buf = buffer.create(ch.cursor); buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        local r, c = Lync.inst.read(buf, 0, ch.refs)
        expect(r):toBe(part); expect(c):toBe(2)
        part:Destroy()
    end)
    it("no _directWrite (needs ch.refs)", function(): () expect((Lync.inst :: any)._directWrite):toBeNil() end)
end)

return nil

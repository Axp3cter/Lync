--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe ("Instance round-trip", function (): ()
    it ("Part reference", function (): ()
        local part = Instance.new ("Part")
        local ch = Channel.create ()
        Lync.inst.write (ch, part)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local result, consumed = Lync.inst.read (buf, 0, ch.refs)
        expect (consumed):toBe (2)
        expect (result):toBe (part)
        part:Destroy ()
    end)
    it ("Folder reference", function (): ()
        local folder = Instance.new ("Folder")
        local ch = Channel.create ()
        Lync.inst.write (ch, folder)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local result = Lync.inst.read (buf, 0, ch.refs)
        expect (result):toBe (folder)
        folder:Destroy ()
    end)
    it ("multiple instances in order", function (): ()
        local a, b, c = Instance.new ("Part"), Instance.new ("Part"), Instance.new ("Part")
        local ch = Channel.create ()
        Lync.inst.write (ch, a)
        Lync.inst.write (ch, b)
        Lync.inst.write (ch, c)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local r1, n1 = Lync.inst.read (buf, 0, ch.refs)
        local r2, n2 = Lync.inst.read (buf, n1, ch.refs)
        local r3, _ = Lync.inst.read (buf, n1 + n2, ch.refs)
        expect (r1):toBe (a)
        expect (r2):toBe (b)
        expect (r3):toBe (c)
        a:Destroy ()
        b:Destroy ()
        c:Destroy ()
    end)
end)

describe ("Instance wire", function (): ()
    it ("uses 2 bytes", function (): ()
        local ch = Channel.create ()
        Lync.inst.write (ch, Instance.new ("Part"))
        expect (ch.cursor):toBe (2)
    end)
    it ("_size is 2", function (): ()
        expect ((Lync.inst :: any)._size):toBe (2)
    end)
    it ("writes 1-based index", function (): ()
        local ch = Channel.create ()
        Lync.inst.write (ch, Instance.new ("Part"))
        expect (buffer.readu16 (ch.buff, 0)):toBe (1)
        Lync.inst.write (ch, Instance.new ("Part"))
        expect (buffer.readu16 (ch.buff, 2)):toBe (2)
    end)
end)

describe ("Instance errors", function (): ()
    it ("throws on nil refs array", function (): ()
        local buf = buffer.create (2)
        buffer.writeu16 (buf, 0, 1)
        expect (function (): ()
            Lync.inst.read (buf, 0, nil)
        end):toThrow ("requires refs array")
    end)
    it ("throws on invalid ref index", function (): ()
        local buf = buffer.create (2)
        buffer.writeu16 (buf, 0, 99)
        expect (function (): ()
            Lync.inst.read (buf, 0, {})
        end):toThrow ("ref index out of bounds")
    end)
end)

return nil

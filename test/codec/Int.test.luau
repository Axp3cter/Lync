--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("int: u8 [0, 255]", function(): ()
    local c = Lync.int(0, 255)
    it("_size = 1", function(): ()
        expect((c :: any)._size):toBe(1)
    end)
    it("0", function(): ()
        expect(roundTrip(c, 0)):toBe(0)
    end)
    it("1", function(): ()
        expect(roundTrip(c, 1)):toBe(1)
    end)
    it("127", function(): ()
        expect(roundTrip(c, 127)):toBe(127)
    end)
    it("128", function(): ()
        expect(roundTrip(c, 128)):toBe(128)
    end)
    it("255", function(): ()
        expect(roundTrip(c, 255)):toBe(255)
    end)
end)


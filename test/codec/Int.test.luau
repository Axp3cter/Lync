        expect(roundTrip(c, -1)):toBe(-1)
    end)
    it("0", function(): ()
        expect(roundTrip(c, 0)):toBe(0)
    end)
    it("127", function(): ()
        expect(roundTrip(c, 127)):toBe(127)
    end)
end)


describe("int: narrow ranges pick smallest wire type", function(): ()
    it("[0, 100] = u8 (1 byte)", function(): ()
        expect((Lync.int(0, 100) :: any)._size):toBe(1)
    end)
    it("[0, 300] = u16 (2 bytes)", function(): ()
        expect((Lync.int(0, 300) :: any)._size):toBe(2)
    end)
    it("[0, 70000] = u32 (4 bytes)", function(): ()
        expect((Lync.int(0, 70000) :: any)._size):toBe(4)
    end)
    it("[-10, 10] = i8 (1 byte)", function(): ()
        expect((Lync.int(-10, 10) :: any)._size):toBe(1)
    end)
    it("[-200, 200] = i16 (2 bytes)", function(): ()
        expect((Lync.int(-200, 200) :: any)._size):toBe(2)
    end)
    it("[-40000, 40000] = i32 (4 bytes)", function(): ()
        expect((Lync.int(-40000, 40000) :: any)._size):toBe(4)
    end)
end)

describe("int: metadata for Gate", function(): ()
    it("_isInteger = true", function(): ()
        expect((Lync.int(0, 255) :: any)._isInteger):toBe(true)
    end)
    it("_typeCheck = number", function(): ()
        expect((Lync.int(0, 255) :: any)._typeCheck):toBe("number")
    end)
    it("_min matches arg", function(): ()
        expect((Lync.int(-10, 50) :: any)._min):toBe(-10)
    end)
    it("_max matches arg", function(): ()
        expect((Lync.int(-10, 50) :: any)._max):toBe(50)
    end)
end)

describe("int: define-time errors", function(): ()
    it("min > max", function(): ()
        expect(function(): ()
            Lync.int(10, 5)
        end):toThrow("min")
    end)
    it("non-integer min", function(): ()
        expect(function(): ()
            Lync.int(0.5, 10)
        end):toThrow("integer")
    end)
    it("non-integer max", function(): ()
        expect(function(): ()
            Lync.int(0, 10.5)
        end):toThrow("integer")
    end)
    it("exceeds i32", function(): ()
        expect(function(): ()
            Lync.int(-3000000000, 3000000000)
        end):toThrow("i32")
    end)
end)

return nil

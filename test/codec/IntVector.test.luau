--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("IntVector.vec2int16", function (): ()
    it ("round-trips origin", function (): ()
        local r = roundTrip (Lync.vec2int16, Vector2int16.new (0, 0))
        expect (r.X):toBe (0)
        expect (r.Y):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.vec2int16, Vector2int16.new (100, 200))
        expect (r.X):toBe (100)
        expect (r.Y):toBe (200)
    end)
    it ("round-trips negative", function (): ()
        local r = roundTrip (Lync.vec2int16, Vector2int16.new (-100, -200))
        expect (r.X):toBe (-100)
        expect (r.Y):toBe (-200)
    end)
    it ("round-trips i16 bounds", function (): ()
        local r = roundTrip (Lync.vec2int16, Vector2int16.new (-32768, 32767))
        expect (r.X):toBe (-32768)
        expect (r.Y):toBe (32767)
    end)
    it ("uses 4 bytes", function (): ()
        local _, w = roundTrip (Lync.vec2int16, Vector2int16.new (1, 2))
        expect (w):toBe (4)
    end)
    it ("_size is 4", function (): ()
        expect ((Lync.vec2int16 :: any)._size):toBe (4)
    end)
end)

describe ("IntVector.vec3int16", function (): ()
    it ("round-trips origin", function (): ()
        local r = roundTrip (Lync.vec3int16, Vector3int16.new (0, 0, 0))
        expect (r.X):toBe (0)
        expect (r.Y):toBe (0)
        expect (r.Z):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.vec3int16, Vector3int16.new (10, 20, 30))
        expect (r.X):toBe (10)
        expect (r.Y):toBe (20)
        expect (r.Z):toBe (30)
    end)
    it ("round-trips negative", function (): ()
        local r = roundTrip (Lync.vec3int16, Vector3int16.new (-1, -2, -3))
        expect (r.X):toBe (-1)
        expect (r.Y):toBe (-2)
        expect (r.Z):toBe (-3)
    end)
    it ("round-trips i16 bounds", function (): ()
        local r = roundTrip (Lync.vec3int16, Vector3int16.new (-32768, 0, 32767))
        expect (r.X):toBe (-32768)
        expect (r.Y):toBe (0)
        expect (r.Z):toBe (32767)
    end)
    it ("uses 6 bytes", function (): ()
        local _, w = roundTrip (Lync.vec3int16, Vector3int16.new (1, 2, 3))
        expect (w):toBe (6)
    end)
    it ("_size is 6", function (): ()
        expect ((Lync.vec3int16 :: any)._size):toBe (6)
    end)
end)

return nil

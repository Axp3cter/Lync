--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("vec2int16", function(): ()
    it("_size = 4", function(): ()
        expect((Lync.vec2int16 :: any)._size):toBe(4)
    end)
    it("positive", function(): ()
        local r = roundTrip(Lync.vec2int16, Vector2int16.new(100, 200))
        expect(r.X):toBe(100)
        expect(r.Y):toBe(200)
    end)
    it("negative", function(): ()
        local r = roundTrip(Lync.vec2int16, Vector2int16.new(-100, -200))
        expect(r.X):toBe(-100)
        expect(r.Y):toBe(-200)
    end)
    it("zero", function(): ()
        local r = roundTrip(Lync.vec2int16, Vector2int16.new(0, 0))
        expect(r.X):toBe(0)
    end)
    it("boundary i16", function(): ()
        local r = roundTrip(Lync.vec2int16, Vector2int16.new(-32768, 32767))
        expect(r.X):toBe(-32768)
        expect(r.Y):toBe(32767)
    end)
    it("_typeCheck = Vector2int16", function(): ()
        expect((Lync.vec2int16 :: any)._typeCheck):toBe("Vector2int16")
    end)
end)

describe("vec3int16", function(): ()
    it("_size = 6", function(): ()
        expect((Lync.vec3int16 :: any)._size):toBe(6)
    end)
    it("positive", function(): ()
        local r = roundTrip(Lync.vec3int16, Vector3int16.new(10, 20, 30))
        expect(r.X):toBe(10)
        expect(r.Y):toBe(20)
        expect(r.Z):toBe(30)
    end)
    it("negative", function(): ()
        local r = roundTrip(Lync.vec3int16, Vector3int16.new(-10, -20, -30))
        expect(r.X):toBe(-10)
        expect(r.Y):toBe(-20)
        expect(r.Z):toBe(-30)
    end)
    it("boundary i16", function(): ()
        local r = roundTrip(Lync.vec3int16, Vector3int16.new(-32768, 0, 32767))
        expect(r.X):toBe(-32768)
        expect(r.Z):toBe(32767)
    end)
    it("_typeCheck = Vector3int16", function(): ()
        expect((Lync.vec3int16 :: any)._typeCheck):toBe("Vector3int16")
    end)
end)

return nil

--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("map basic", function(): ()
    it("empty = 1 byte", function(): ()
        local _, w = roundTrip(Lync.map(Lync.string, Lync.int(0, 255)), {})
        expect(w):toBe(1)
    end)
    it("string → number", function(): ()
        local r = roundTrip(Lync.map(Lync.string, Lync.int(0, 255)), { hp = 100, mp = 50 })
        expect(r.hp):toBe(100)
        expect(r.mp):toBe(50)
    end)
    it("u8 → string", function(): ()
        local r = roundTrip(Lync.map(Lync.int(0, 255), Lync.string), { [1] = "one", [2] = "two" })
        expect(r[1]):toBe("one")
        expect(r[2]):toBe("two")
    end)
    it("single entry", function(): ()
        local r = roundTrip(Lync.map(Lync.string, Lync.int(0, 255)), { score = 42 })
        expect(r.score):toBe(42)
    end)
    it("10 entries", function(): ()
        local data: any = {}
        for i = 1, 10 do
            data["k" .. i] = i
        end
        local r = roundTrip(Lync.map(Lync.string, Lync.int(0, 255)), data)
        expect(r.k1):toBe(1)
        expect(r.k10):toBe(10)
    end)
    it("nested map", function(): ()
        local inner = Lync.map(Lync.string, Lync.int(0, 255))
        local outer = Lync.map(Lync.string, inner)
        local r = roundTrip(outer, { a = { x = 1 }, b = { y = 2 } })
        expect(r.a.x):toBe(1)
        expect(r.b.y):toBe(2)
    end)
end)

describe("map maxCount", function(): ()
    it("rejects on read", function(): ()
        local ch = Channel.create()
        Lync.map(Lync.int(0, 255), Lync.int(0, 255)).write(ch, { [1] = 10, [2] = 20, [3] = 30 })
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        expect(function(): ()
            Lync.map(Lync.int(0, 255), Lync.int(0, 255), 2).read(buf, 0, nil)
        end):toThrow("exceeds max")
    end)
end)

describe("deltaMap", function(): ()
    it("identical = 1 byte", function(): ()
        local c = Lync.deltaMap(Lync.string, Lync.int(0, 255))
        local ch = Channel.create()
        c.write(ch, { hp = 100 })
        ch.cursor = 0
        c.write(ch, { hp = 100 })
        expect(ch.cursor):toBe(1)
    end)
    it("changed triggers larger write", function(): ()
        local c = Lync.deltaMap(Lync.string, Lync.int(0, 255))
        local ch = Channel.create()
        c.write(ch, { hp = 100 })
        ch.cursor = 0
        c.write(ch, { hp = 80 })
        expect(ch.cursor):toBeGreaterThan(1)
    end)
    it("_isDelta = true", function(): ()
        expect((Lync.deltaMap(Lync.string, Lync.int(0, 255)) :: any)._isDelta):toBe(true)
    end)
end)

return nil

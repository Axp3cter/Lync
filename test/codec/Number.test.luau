--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("u8", function (): ()
    it ("0", function (): ()
        expect (roundTrip (Lync.u8, 0)):toBe (0)
    end)
    it ("255", function (): ()
        expect (roundTrip (Lync.u8, 255)):toBe (255)
    end)
    it ("1 byte", function (): ()
        local _, w = roundTrip (Lync.u8, 1)
        expect (w):toBe (1)
    end)
    it ("_size = 1", function (): ()
        expect ((Lync.u8 :: any)._size):toBe (1)
    end)
end)

describe ("u16", function (): ()
    it ("0", function (): ()
        expect (roundTrip (Lync.u16, 0)):toBe (0)
    end)
    it ("65535", function (): ()
        expect (roundTrip (Lync.u16, 65535)):toBe (65535)
    end)
    it ("2 bytes", function (): ()

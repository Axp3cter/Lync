describe ("f32", function (): ()
    it ("0", function (): ()
        expect (roundTrip (Lync.f32, 0)):toBe (0)
    end)
    it ("pi", function (): ()
        expect (roundTrip (Lync.f32, math.pi)):toBeCloseTo (math.pi, 0.001)
    end)
    it ("negative", function (): ()
        expect (roundTrip (Lync.f32, -1.5)):toBeCloseTo (-1.5)
    end)
    it ("4 bytes", function (): ()
        local _, w = roundTrip (Lync.f32, 0)
        expect (w):toBe (4)
    end)
end)

describe ("f64", function (): ()
    it ("0", function (): ()
        expect (roundTrip (Lync.f64, 0)):toBe (0)
    end)
    it ("pi exact", function (): ()
        expect (roundTrip (Lync.f64, math.pi)):toBe (math.pi)
    end)
    it ("huge", function (): ()
        expect (roundTrip (Lync.f64, 1e300)):toBe (1e300)
    end)
    it ("8 bytes", function (): ()
        local _, w = roundTrip (Lync.f64, 0)
        expect (w):toBe (8)
    end)
    it ("_size = 8", function (): ()
        expect ((Lync.f64 :: any)._size):toBe (8)
    end)
end)

describe ("sequential writes", function (): ()
    it ("u8 then u16 no interference", function (): ()
        local Channel = require (script.Parent.Parent.Parent.internal.Channel)
        local ch = Channel.create ()
        Lync.u8.write (ch, 42)
        Lync.u16.write (ch, 1000)
        expect (ch.cursor):toBe (3)
        local buf = buffer.create (3)
        buffer.copy (buf, 0, ch.buff, 0, 3)
        local v1, c1 = Lync.u8.read (buf, 0, nil)
        local v2, c2 = Lync.u16.read (buf, 1, nil)
        expect (v1):toBe (42)
        expect (c1):toBe (1)
        expect (v2):toBe (1000)
        expect (c2):toBe (2)
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("f32", function(): ()
    it("_size = 4", function(): ()
        expect((Lync.f32 :: any)._size):toBe(4)
    end)
    it("0", function(): ()
        expect(roundTrip(Lync.f32, 0)):toBe(0)
    end)
    it("1.5", function(): ()
        expect(roundTrip(Lync.f32, 1.5)):toBeCloseTo(1.5)
    end)
    it("-1", function(): ()
        expect(roundTrip(Lync.f32, -1)):toBe(-1)
    end)
    it("large value", function(): ()
        expect(roundTrip(Lync.f32, 1e30)):toBeCloseTo(1e30, 1e23)
    end)
    it("small value", function(): ()
        expect(roundTrip(Lync.f32, 0.0001)):toBeCloseTo(0.0001, 1e-7)
    end)
    it("wire = 4 bytes", function(): ()
        local _, w = roundTrip(Lync.f32, 42)
        expect(w):toBe(4)
    end)
    it("has _directWrite", function(): ()
        expect((Lync.f32 :: any)._directWrite):toBeTruthy()
    end)
    it("has _directRead", function(): ()
        expect((Lync.f32 :: any)._directRead):toBeTruthy()
    end)
end)

describe("f64", function(): ()
    it("_size = 8", function(): ()
        expect((Lync.f64 :: any)._size):toBe(8)
    end)
    it("0", function(): ()
        expect(roundTrip(Lync.f64, 0)):toBe(0)
    end)
    it("pi", function(): ()
        expect(roundTrip(Lync.f64, math.pi)):toBeCloseTo(math.pi, 1e-15)
    end)
    it("-1", function(): ()
        expect(roundTrip(Lync.f64, -1)):toBe(-1)
    end)
    it("huge", function(): ()
        expect(roundTrip(Lync.f64, 1e300)):toBeCloseTo(1e300, 1e285)
    end)
    it("tiny", function(): ()
        expect(roundTrip(Lync.f64, 1e-300)):toBeCloseTo(1e-300, 1e-315)
    end)
    it("wire = 8 bytes", function(): ()
        local _, w = roundTrip(Lync.f64, 42)
        expect(w):toBe(8)
    end)
end)

return nil

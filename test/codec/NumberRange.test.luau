--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("NumberRange", function (): ()
    it ("round-trips zero", function (): ()
        local r = roundTrip (Lync.numberRange, NumberRange.new (0, 0))
        expect (r.Min):toBe (0)
        expect (r.Max):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.numberRange, NumberRange.new (1.5, 10.5))
        expect (r.Min):toBeCloseTo (1.5)
        expect (r.Max):toBeCloseTo (10.5)
    end)
    it ("round-trips negative", function (): ()
        local r = roundTrip (Lync.numberRange, NumberRange.new (-100, -1))
        expect (r.Min):toBeCloseTo (-100)
        expect (r.Max):toBeCloseTo (-1)
    end)
    it ("round-trips equal min max", function (): ()
        local r = roundTrip (Lync.numberRange, NumberRange.new (42))
        expect (r.Min):toBeCloseTo (42)
        expect (r.Max):toBeCloseTo (42)
    end)
    it ("uses 8 bytes", function (): ()
        local _, w = roundTrip (Lync.numberRange, NumberRange.new (0, 1))
        expect (w):toBe (8)
    end)
    it ("_size is 8", function (): ()
        expect ((Lync.numberRange :: any)._size):toBe (8)
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("optional", function(): ()
    it("nil = 1 byte", function(): ()
        local r, w = roundTrip(Lync.optional(Lync.int(0, 255)), nil)
        expect(r):toBeNil()
        expect(w):toBe(1)
    end)
    it("present value", function(): ()
        local r, w = roundTrip(Lync.optional(Lync.int(0, 255)), 42)
        expect(r):toBe(42)
        expect(w):toBe(2)
    end)
    it("present zero", function(): ()
        expect(roundTrip(Lync.optional(Lync.int(0, 255)), 0)):toBe(0)
    end)
    it("optional string nil", function(): ()
        expect(roundTrip(Lync.optional(Lync.string), nil)):toBeNil()
    end)
    it("optional string present", function(): ()
        expect(roundTrip(Lync.optional(Lync.string), "hi")):toBe("hi")
    end)
    it("optional struct nil", function(): ()
        local c = Lync.optional(Lync.struct({ x = Lync.int(0, 255) }))
        expect(roundTrip(c, nil)):toBeNil()
    end)
    it("optional struct present", function(): ()
        local c = Lync.optional(Lync.struct({ x = Lync.int(0, 255) }))
        local r = roundTrip(c, { x = 42 })
        expect(r.x):toBe(42)
    end)
    it("nested optional", function(): ()
        local c = Lync.optional(Lync.optional(Lync.int(0, 255)))
        expect(roundTrip(c, nil)):toBeNil()
        expect(roundTrip(c, 42)):toBe(42)
    end)
    it("optional bool", function(): ()
        expect(roundTrip(Lync.optional(Lync.bool), true)):toBe(true)
        expect(roundTrip(Lync.optional(Lync.bool), false)):toBe(false)
        expect(roundTrip(Lync.optional(Lync.bool), nil)):toBeNil()
    end)
end)

return nil

describe ("Primitive.f32", function (): ()
    it ("round-trips pi", function (): ()
        expect (roundTrip (Lync.f32, math.pi)):toBeCloseTo (math.pi, 0.0001)
    end)
    it ("round-trips 0", function (): ()
        expect (roundTrip (Lync.f32, 0)):toBe (0)
    end)
    it ("round-trips -1.5", function (): ()
        expect (roundTrip (Lync.f32, -1.5)):toBeCloseTo (-1.5)
    end)
    it ("round-trips 1.0 exact", function (): ()
        expect (roundTrip (Lync.f32, 1.0)):toBe (1.0)
    end)
    it ("round-trips very small", function (): ()
        expect (roundTrip (Lync.f32, 1e-30)):toBeCloseTo (1e-30, 1e-35)
    end)
    it ("round-trips very large", function (): ()
        expect (roundTrip (Lync.f32, 1e30)):toBeCloseTo (1e30, 1e25)
    end)
    it ("uses 4 bytes", function (): ()
        local _, w = roundTrip (Lync.f32, 1.0)
        expect (w):toBe (4)
    end)
    it ("_size is 4", function (): ()
        expect ((Lync.f32 :: any)._size):toBe (4)
    end)
end)


describe ("Primitive.bool", function (): ()
    it ("round-trips true", function (): ()
        expect (roundTrip (Lync.bool, true)):toBe (true)
    end)
    it ("round-trips false", function (): ()
        expect (roundTrip (Lync.bool, false)):toBe (false)
    end)
    it ("uses 1 byte", function (): ()
        local _, w = roundTrip (Lync.bool, true)
        expect (w):toBe (1)
    end)
    it ("_size is 1", function (): ()
        expect ((Lync.bool :: any)._size):toBe (1)
    end)
    it ("_isBool is true", function (): ()
        expect ((Lync.bool :: any)._isBool):toBe (true)
    end)
    it ("reads 0xFF as true", function (): ()
        local ch = Channel.create ()
        Channel.alloc (ch, 1)
        buffer.writeu8 (ch.buff, 0, 0xFF)
        ch.cursor = 1
        local buf = buffer.create (1)
        buffer.copy (buf, 0, ch.buff, 0, 1)
        expect (Lync.bool.read (buf, 0, nil)):toBe (true)
    end)
    it ("reads 0x02 as true", function (): ()
        local buf = buffer.create (1)
        buffer.writeu8 (buf, 0, 2)
        expect (Lync.bool.read (buf, 0, nil)):toBe (true)
    end)
    it ("reads 0x00 as false", function (): ()
        local buf = buffer.create (1)
        buffer.writeu8 (buf, 0, 0)
        expect (Lync.bool.read (buf, 0, nil)):toBe (false)
    end)
    it ("writes true as 1", function (): ()
        local ch = Channel.create ()
        Lync.bool.write (ch, true)
        expect (buffer.readu8 (ch.buff, 0)):toBe (1)
    end)
    it ("writes false as 0", function (): ()
        local ch = Channel.create ()
        Lync.bool.write (ch, false)
        expect (buffer.readu8 (ch.buff, 0)):toBe (0)
    end)
end)

describe ("Primitive sequential writes", function (): ()
    it ("multiple writes to same channel don't clobber", function (): ()
        local ch = Channel.create ()
        Lync.u8.write (ch, 0xAA)
        Lync.u16.write (ch, 0xBBCC)
        Lync.u32.write (ch, 0xDDEEFF00)
        expect (ch.cursor):toBe (7)
        expect (buffer.readu8 (ch.buff, 0)):toBe (0xAA)
        expect (buffer.readu16 (ch.buff, 1)):toBe (0xBBCC)
        expect (buffer.readu32 (ch.buff, 3)):toBe (0xDDEEFF00)
    end)
end)

return nil

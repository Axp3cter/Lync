--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Primitive.u8", function (): ()
    it ("round-trips 0", function (): ()
        expect (roundTrip (Lync.u8, 0)):toBe (0)
    end)
    it ("round-trips 255", function (): ()
        expect (roundTrip (Lync.u8, 255)):toBe (255)
    end)
    it ("round-trips 128", function (): ()
        expect (roundTrip (Lync.u8, 128)):toBe (128)
    end)
    it ("round-trips 1", function (): ()
        expect (roundTrip (Lync.u8, 1)):toBe (1)
    end)
    it ("uses 1 byte", function (): ()
        local _, w = roundTrip (Lync.u8, 42)
        expect (w):toBe (1)
    end)
    it ("_size is 1", function (): ()
        expect ((Lync.u8 :: any)._size):toBe (1)
    end)
    it ("consumed equals written", function (): ()
        local _, w, c = roundTrip (Lync.u8, 99)
        expect (c):toBe (w)
    end)
end)


--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("quantizedFloat", function (): ()
    it ("mid-range", function (): ()
        local c = Lync.quantizedFloat (0, 100, 0.1)
        local r = roundTrip (c, 50)
        expect (r):toBeCloseTo (50, 0.1)
    end)
    it ("min clamp", function (): ()
        local c = Lync.quantizedFloat (0, 100, 0.1)
        local r = roundTrip (c, -10)
        expect (r):toBeCloseTo (0, 0.1)
    end)
    it ("max clamp", function (): ()
        local c = Lync.quantizedFloat (0, 100, 0.1)
        local r = roundTrip (c, 200)
        expect (r):toBeCloseTo (100, 0.1)
    end)
end)

describe ("quantizedVec3", function (): ()
    it ("center", function (): ()
        local c = Lync.quantizedVec3 (0, 100, 0.1)
        local r = roundTrip (c, Vector3.new (50, 50, 50))
        expect (r.X):toBeCloseTo (50, 0.2)
        expect (r.Y):toBeCloseTo (50, 0.2)
        expect (r.Z):toBeCloseTo (50, 0.2)
    end)
    it ("clamps all axes", function (): ()
        local c = Lync.quantizedVec3 (0, 100, 0.1)
        local r = roundTrip (c, Vector3.new (-10, 200, 50))
        expect (r.X):toBeCloseTo (0, 0.2)
        expect (r.Y):toBeCloseTo (100, 0.2)
    end)
end)

describe ("quantizedFloat precision", function (): ()
    it ("exact min", function (): ()
        local c = Lync.quantizedFloat (0, 100, 0.1)
        expect (roundTrip (c, 0)):toBeCloseTo (0, 0.1)
    end)
    it ("exact max", function (): ()
        local c = Lync.quantizedFloat (0, 100, 0.1)
        expect (roundTrip (c, 100)):toBeCloseTo (100, 0.1)
    end)
    it ("resolution honoured", function (): ()
        local c = Lync.quantizedFloat (0, 1, 0.01)
        local a = roundTrip (c, 0.5) :: number
        local b = roundTrip (c, 0.51) :: number
        expect (math.abs (a - b)):toBeLessThan (0.02)
    end)
end)

return nil

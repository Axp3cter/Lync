--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Quantized.float", function (): ()
    local codec = Lync.quantizedFloat (0, 100, 0.1)
    it ("midpoint", function (): ()
        expect (roundTrip (codec, 50)):toBeCloseTo (50, 0.1)
    end)
    it ("min boundary", function (): ()
        expect (roundTrip (codec, 0)):toBeCloseTo (0, 0.1)
    end)
    it ("max boundary", function (): ()
        expect (roundTrip (codec, 100)):toBeCloseTo (100, 0.1)
    end)
    it ("clamps below min", function (): ()
        expect (roundTrip (codec, -50)):toBeCloseTo (0, 0.1)
    end)
    it ("clamps above max", function (): ()
        expect (roundTrip (codec, 200)):toBeCloseTo (100, 0.1)
    end)
    it ("quarter point", function (): ()
        expect (roundTrip (codec, 25)):toBeCloseTo (25, 0.1)
    end)
    it ("near-boundary 0.05", function (): ()
        expect (roundTrip (codec, 0.05)):toBeCloseTo (0.05, 0.1)
    end)
    it ("near-boundary 99.95", function (): ()
        expect (roundTrip (codec, 99.95)):toBeCloseTo (99.95, 0.1)
    end)
    it ("uses 2 bytes for 0-100 at 0.1", function (): ()
        local _, w = roundTrip (codec, 50)
        expect (w):toBe (2)
    end)
end)

describe ("Quantized.float precision guarantee", function (): ()
    it ("every value within declared precision", function (): ()
        local precision = 0.1
        local codec = Lync.quantizedFloat (0, 100, precision)
        for _, v in { 0, 0.05, 1, 10, 25, 50, 75, 90, 99.9, 100 } do
            local result = roundTrip (codec, v)
            local diff = math.abs (result - math.clamp (v, 0, 100))
            expect (diff <= precision):toBe (true)
        end
    end)
end)

describe ("Quantized.float 1-byte range", function (): ()
    local codec = Lync.quantizedFloat (0, 10, 0.1)
    it ("round-trips", function (): ()
        expect (roundTrip (codec, 5)):toBeCloseTo (5, 0.1)
    end)
    it ("uses 1 byte", function (): ()
        local _, w = roundTrip (codec, 5)
        expect (w):toBe (1)
    end)
end)

describe ("Quantized.float 4-byte range", function (): ()
    local codec = Lync.quantizedFloat (0, 1000000, 0.01)
    it ("round-trips", function (): ()
        expect (roundTrip (codec, 500000)):toBeCloseTo (500000, 0.01)
    end)
    it ("uses 4 bytes", function (): ()
        local _, w = roundTrip (codec, 0)
        expect (w):toBe (4)
    end)
end)

describe ("Quantized.float zero-delta", function (): ()
    local codec = Lync.quantizedFloat (42, 42, 0.1)
    it ("always returns constant", function (): ()
        expect (roundTrip (codec, 999)):toBe (42)
    end)
    it ("zero bytes on wire", function (): ()
        local _, w = roundTrip (codec, 0)
        expect (w):toBe (0)
    end)
    it ("_size is 0", function (): ()
        expect ((codec :: any)._size):toBe (0)
    end)
end)

describe ("Quantized.vec3", function (): ()
    local codec = Lync.quantizedVec3 (-500, 500, 0.1)
    it ("origin", function (): ()
        local r = roundTrip (codec, Vector3.zero)
        expect (r.X):toBeCloseTo (0, 0.1)
        expect (r.Y):toBeCloseTo (0, 0.1)
        expect (r.Z):toBeCloseTo (0, 0.1)
    end)
    it ("positive", function (): ()
        local r = roundTrip (codec, Vector3.new (100, 200, 300))
        expect (r.X):toBeCloseTo (100, 0.1)
        expect (r.Y):toBeCloseTo (200, 0.1)
        expect (r.Z):toBeCloseTo (300, 0.1)
    end)
    it ("negative", function (): ()
        local r = roundTrip (codec, Vector3.new (-100, -200, -300))
        expect (r.X):toBeCloseTo (-100, 0.1)
        expect (r.Y):toBeCloseTo (-200, 0.1)
        expect (r.Z):toBeCloseTo (-300, 0.1)
    end)
    it ("clamps at max", function (): ()
        local r = roundTrip (codec, Vector3.new (999, 999, 999))
        expect (r.X):toBeCloseTo (500, 0.1)
    end)
end)

describe ("Quantized.vec3 precision guarantee", function (): ()
    it ("each component within declared precision", function (): ()
        local precision = 0.5
        local codec = Lync.quantizedVec3 (-100, 100, precision)
        local input = Vector3.new (33.3, -77.7, 0.1)
        local r = roundTrip (codec, input)
        expect (math.abs (r.X - 33.3) <= precision):toBe (true)
        expect (math.abs (r.Y - -77.7) <= precision):toBe (true)
        expect (math.abs (r.Z - 0.1) <= precision):toBe (true)
    end)
end)

describe ("Quantized.vec3 zero-delta", function (): ()
    local codec = Lync.quantizedVec3 (5, 5, 0.1)
    it ("returns constant vector", function (): ()
        local r = roundTrip (codec, Vector3.new (999, 999, 999))
        expect (r.X):toBeCloseTo (5, 0.001)
        expect (r.Y):toBeCloseTo (5, 0.001)
    end)
    it ("zero bytes", function (): ()
        local _, w = roundTrip (codec, Vector3.zero)
        expect (w):toBe (0)
    end)
    it ("_size is 0", function (): ()
        expect ((codec :: any)._size):toBe (0)
    end)
end)

describe ("Quantized.vec3 wire size", function (): ()
    it ("1-byte per component (3 total)", function (): ()
        local codec = Lync.quantizedVec3 (0, 10, 0.1)
        local _, w = roundTrip (codec, Vector3.zero)
        expect (w):toBe (3)
    end)
    it ("2-byte per component (6 total)", function (): ()
        local codec = Lync.quantizedVec3 (0, 1000, 0.1)
        local _, w = roundTrip (codec, Vector3.zero)
        expect (w):toBe (6)
    end)
end)

describe ("Quantized validation", function (): ()
    it ("throws min > max", function (): ()
        expect (function (): ()
            Lync.quantizedFloat (100, 0, 0.1)
        end):toThrow ("min")
    end)
    it ("throws precision zero", function (): ()
        expect (function (): ()
            Lync.quantizedFloat (0, 100, 0)
        end):toThrow ("precision")
    end)
    it ("throws precision negative", function (): ()
        expect (function (): ()
            Lync.quantizedFloat (0, 100, -1)
        end):toThrow ("precision")
    end)
    it ("throws vec3 min > max", function (): ()
        expect (function (): ()
            Lync.quantizedVec3 (100, 0, 0.1)
        end):toThrow ("min")
    end)
end)

return nil

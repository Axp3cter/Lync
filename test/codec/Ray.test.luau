--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Ray", function (): ()
    it ("round-trips origin", function (): ()
        local r = roundTrip (Lync.ray, Ray.new (Vector3.zero, Vector3.zero))
        expect (r.Origin.X):toBe (0)
        expect (r.Origin.Y):toBe (0)
        expect (r.Origin.Z):toBe (0)
        expect (r.Direction.X):toBe (0)
        expect (r.Direction.Y):toBe (0)
        expect (r.Direction.Z):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.ray, Ray.new (Vector3.new (1, 2, 3), Vector3.new (0, 1, 0)))
        expect (r.Origin.X):toBeCloseTo (1)
        expect (r.Origin.Y):toBeCloseTo (2)
        expect (r.Origin.Z):toBeCloseTo (3)
        expect (r.Direction.X):toBeCloseTo (0)
        expect (r.Direction.Y):toBeCloseTo (1)
        expect (r.Direction.Z):toBeCloseTo (0)
    end)
    it ("round-trips negative", function (): ()
        local r =
            roundTrip (Lync.ray, Ray.new (Vector3.new (-10, -20, -30), Vector3.new (-1, 0, 0)))
        expect (r.Origin.X):toBeCloseTo (-10)
        expect (r.Direction.X):toBeCloseTo (-1)
    end)
    it ("round-trips large", function (): ()
        local r = roundTrip (Lync.ray, Ray.new (Vector3.new (1e5, 0, -1e5), Vector3.new (0, 0, 1)))
        expect (r.Origin.X):toBeCloseTo (1e5, 10)
        expect (r.Origin.Z):toBeCloseTo (-1e5, 10)
    end)
    it ("uses 24 bytes", function (): ()
        local _, w = roundTrip (Lync.ray, Ray.new (Vector3.zero, Vector3.one))
        expect (w):toBe (24)
    end)
    it ("_size is 24", function (): ()
        expect ((Lync.ray :: any)._size):toBe (24)
    end)
end)

return nil

--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("Special.nothing", function (): ()
    it ("writes 0 bytes", function (): ()
        local _, w = roundTrip (Lync.nothing, "anything")
        expect (w):toBe (0)
    end)
    it ("reads nil", function (): ()
        expect (roundTrip (Lync.nothing, nil)):toBeNil ()
    end)
    it ("consumed = 0", function (): ()
        local _, _, c = roundTrip (Lync.nothing, nil)
        expect (c):toBe (0)
    end)
end)

describe ("Special.unknown", function (): ()
    it ("round-trips Part", function (): ()
        local part = Instance.new ("Part")
        local ch = Channel.create ()
        Lync.unknown.write (ch, part)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local r, n = Lync.unknown.read (buf, 0, ch.refs)
        expect (n):toBe (2)
        expect (r):toBe (part)
        part:Destroy ()
    end)
    it ("round-trips string", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "hello")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (Lync.unknown.read (buf, 0, ch.refs)):toBe ("hello")
    end)
    it ("round-trips number", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, 42)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (Lync.unknown.read (buf, 0, ch.refs)):toBe (42)
    end)
    it ("round-trips table", function (): ()
        local t = { a = 1 }
        local ch = Channel.create ()
        Lync.unknown.write (ch, t)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (Lync.unknown.read (buf, 0, ch.refs)):toBe (t)
    end)
    it ("preserves order for multiple values", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "first")
        Lync.unknown.write (ch, "second")
        Lync.unknown.write (ch, "third")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local a, n1 = Lync.unknown.read (buf, 0, ch.refs)
        local b, n2 = Lync.unknown.read (buf, n1, ch.refs)
        local c, _ = Lync.unknown.read (buf, n1 + n2, ch.refs)
        expect (a):toBe ("first")
        expect (b):toBe ("second")
        expect (c):toBe ("third")
    end)
    it ("returns nil when refs is nil", function (): ()
        local buf = buffer.create (2)
        buffer.writeu16 (buf, 0, 1)
        expect (Lync.unknown.read (buf, 0, nil)):toBeNil ()
    end)
    it ("uses 2 bytes per write", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "x")
        expect (ch.cursor):toBe (2)
    end)
end)

describe ("Special.auto types", function (): ()
    it ("nil", function (): ()
        expect (roundTrip (Lync.auto, nil)):toBeNil ()
    end)
    it ("true", function (): ()
        expect (roundTrip (Lync.auto, true)):toBe (true)
    end)
    it ("false", function (): ()
        expect (roundTrip (Lync.auto, false)):toBe (false)
    end)
    it ("u8 (42)", function (): ()
        expect (roundTrip (Lync.auto, 42)):toBe (42)
    end)
    it ("u8 (0)", function (): ()
        expect (roundTrip (Lync.auto, 0)):toBe (0)
    end)
    it ("u8 (255)", function (): ()
        expect (roundTrip (Lync.auto, 255)):toBe (255)
    end)
    it ("u16 (1000)", function (): ()
        expect (roundTrip (Lync.auto, 1000)):toBe (1000)
    end)
    it ("u16 (65535)", function (): ()
        expect (roundTrip (Lync.auto, 65535)):toBe (65535)
    end)
    it ("u32 (70000)", function (): ()
        expect (roundTrip (Lync.auto, 70000)):toBe (70000)
    end)
    it ("u32 (max)", function (): ()
        expect (roundTrip (Lync.auto, 4294967295)):toBe (4294967295)
    end)
    it ("i8 (-5)", function (): ()
        expect (roundTrip (Lync.auto, -5)):toBe (-5)
    end)
    it ("i8 (-128)", function (): ()
        expect (roundTrip (Lync.auto, -128)):toBe (-128)
    end)
    it ("i16 (-1000)", function (): ()
        expect (roundTrip (Lync.auto, -1000)):toBe (-1000)
    end)
    it ("i16 (-32768)", function (): ()
        expect (roundTrip (Lync.auto, -32768)):toBe (-32768)
    end)
    it ("i32 (-100000)", function (): ()
        expect (roundTrip (Lync.auto, -100000)):toBe (-100000)
    end)
    it ("f32 (1.5)", function (): ()
        expect (roundTrip (Lync.auto, 1.5)):toBeCloseTo (1.5)
    end)
    it ("f64 (pi)", function (): ()
        expect (roundTrip (Lync.auto, math.pi)):toBe (math.pi)
    end)
    it ("f64 (huge int)", function (): ()
        expect (roundTrip (Lync.auto, 2 ^ 53)):toBe (2 ^ 53)
    end)
    it ("string", function (): ()
        expect (roundTrip (Lync.auto, "hello")):toBe ("hello")
    end)
    it ("empty string", function (): ()
        expect (roundTrip (Lync.auto, "")):toBe ("")
    end)
    it ("Vector2", function (): ()
        local r = roundTrip (Lync.auto, Vector2.new (3, 4))
        expect (r.X):toBeCloseTo (3)
        expect (r.Y):toBeCloseTo (4)
    end)
    it ("Vector3", function (): ()
        local r = roundTrip (Lync.auto, Vector3.new (1, 2, 3))
        expect (r.X):toBeCloseTo (1)
        expect (r.Y):toBeCloseTo (2)
        expect (r.Z):toBeCloseTo (3)
    end)
    it ("Color3", function (): ()
        local r = roundTrip (Lync.auto, Color3.fromRGB (255, 128, 0))
        expect (r.R):toBeCloseTo (1, 0.01)
        expect (r.G):toBeCloseTo (128 / 255, 0.01)
    end)
    it ("CFrame", function (): ()
        local r = roundTrip (Lync.auto, CFrame.new (1, 2, 3))
        expect (r.Position.X):toBeCloseTo (1)
    end)
    it ("buffer", function (): ()
        local inp = buffer.create (4)
        buffer.writeu32 (inp, 0, 0xDEADBEEF)
        local r = roundTrip (Lync.auto, inp)
        expect (buffer.len (r)):toBe (4)
        expect (buffer.readu32 (r, 0)):toBe (0xDEADBEEF)
    end)
end)

describe ("Special.auto wire sizes", function (): ()
    it ("nil = 1", function (): ()
        local _, w = roundTrip (Lync.auto, nil)
        expect (w):toBe (1)
    end)
    it ("bool = 2", function (): ()
        local _, w = roundTrip (Lync.auto, true)
        expect (w):toBe (2)
    end)
    it ("u8 = 2", function (): ()
        local _, w = roundTrip (Lync.auto, 42)
        expect (w):toBe (2)
    end)
    it ("u16 = 3", function (): ()
        local _, w = roundTrip (Lync.auto, 1000)
        expect (w):toBe (3)
    end)
    it ("u32 = 5", function (): ()
        local _, w = roundTrip (Lync.auto, 70000)
        expect (w):toBe (5)
    end)
    it ("i8 = 2", function (): ()
        local _, w = roundTrip (Lync.auto, -5)
        expect (w):toBe (2)
    end)
    it ("i16 = 3", function (): ()
        local _, w = roundTrip (Lync.auto, -1000)
        expect (w):toBe (3)
    end)
    it ("i32 = 5", function (): ()
        local _, w = roundTrip (Lync.auto, -100000)
        expect (w):toBe (5)
    end)
    it ("f32 = 5", function (): ()
        local _, w = roundTrip (Lync.auto, 1.5)
        expect (w):toBe (5)
    end)
    it ("f64 = 9", function (): ()
        local _, w = roundTrip (Lync.auto, math.pi)
        expect (w):toBe (9)
    end)
end)

describe ("Special.auto number tag selection", function (): ()
    it ("0 → u8", function (): ()
        local _, w = roundTrip (Lync.auto, 0)
        expect (w):toBe (2)
    end)
    it ("255 → u8", function (): ()
        local _, w = roundTrip (Lync.auto, 255)
        expect (w):toBe (2)
    end)
    it ("256 → u16", function (): ()
        local _, w = roundTrip (Lync.auto, 256)
        expect (w):toBe (3)
    end)
    it ("65536 → u32", function (): ()
        local _, w = roundTrip (Lync.auto, 65536)
        expect (w):toBe (5)
    end)
    it ("-1 → i8", function (): ()
        local _, w = roundTrip (Lync.auto, -1)
        expect (w):toBe (2)
    end)
    it ("-129 → i16", function (): ()
        local _, w = roundTrip (Lync.auto, -129)
        expect (w):toBe (3)
    end)
    it ("-32769 → i32", function (): ()
        local _, w = roundTrip (Lync.auto, -32769)
        expect (w):toBe (5)
    end)
end)

describe ("Special.auto errors", function (): ()
    it ("throws on Instance", function (): ()
        expect (function (): ()
            local ch = Channel.create ()
            Lync.auto.write (ch, Instance.new ("Part"))
        end):toThrow ("unsupported type")
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("string", function (): ()
    it ("empty", function (): ()
        expect (roundTrip (Lync.string, "")):toBe ("")
    end)
    it ("short", function (): ()
        expect (roundTrip (Lync.string, "hi")):toBe ("hi")
    end)
    it ("unicode", function (): ()
        expect (roundTrip (Lync.string, "café")):toBe ("café")
    end)
    it ("long", function (): ()
        local s = string.rep ("x", 1000)
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
    it ("null bytes", function (): ()
        expect (roundTrip (Lync.string, "a\0b")):toBe ("a\0b")
    end)
end)

describe ("boundedString", function (): ()
    it ("accepts within limit", function (): ()
        local b = Lync.boundedString (10)
        local Channel = require (script.Parent.Parent.Parent.internal.Channel)
        local ch = Channel.create ()
        Lync.string.write (ch, "hello")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (b.read (buf, 0, nil)):toBe ("hello")
    end)
    it ("rejects over limit", function (): ()
        local b = Lync.boundedString (5)
        local Channel = require (script.Parent.Parent.Parent.internal.Channel)
        local ch = Channel.create ()
        Lync.string.write (ch, "toolong")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (function (): ()
            b.read (buf, 0, nil)
        end):toThrow ("exceeds max")
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("String round-trip", function (): ()
    it ("empty string", function (): ()
        expect (roundTrip (Lync.string, "")):toBe ("")
    end)
    it ("single char", function (): ()
        expect (roundTrip (Lync.string, "a")):toBe ("a")
    end)
    it ("short ASCII", function (): ()
        expect (roundTrip (Lync.string, "hello")):toBe ("hello")
    end)
    it ("127 chars (1-byte varint boundary)", function (): ()
        local s = string.rep ("x", 127)
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
    it ("128 chars (2-byte varint)", function (): ()
        local s = string.rep ("x", 128)
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
    it ("1000 chars", function (): ()
        local s = string.rep ("a", 1000)
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
    it ("UTF-8 multibyte", function (): ()
        expect (roundTrip (Lync.string, "日本語テスト")):toBe ("日本語テスト")
    end)
    it ("mixed ASCII and UTF-8", function (): ()
        expect (roundTrip (Lync.string, "hello 世界")):toBe ("hello 世界")
    end)
    it ("string with null bytes", function (): ()
        local s = "a\0b\0c"
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
    it ("all byte values 0-255", function (): ()
        local t = {}
        for i = 0, 255 do
            t[i + 1] = string.char (i)
        end
        local s = table.concat (t)
        expect (roundTrip (Lync.string, s)):toBe (s)
    end)
end)

describe ("String wire size", function (): ()
    it ("empty = 1 byte (varint 0)", function (): ()
        local _, w = roundTrip (Lync.string, "")
        expect (w):toBe (1)
    end)
    it ("5 chars = 6 bytes", function (): ()
        local _, w = roundTrip (Lync.string, "abcde")
        expect (w):toBe (6)
    end)
    it ("127 chars = 128 bytes (1-byte varint + 127)", function (): ()
        local _, w = roundTrip (Lync.string, string.rep ("x", 127))
        expect (w):toBe (128)
    end)
    it ("128 chars = 130 bytes (2-byte varint + 128)", function (): ()
        local _, w = roundTrip (Lync.string, string.rep ("x", 128))
        expect (w):toBe (130)
    end)
    it ("no _size (variable length)", function (): ()
        expect ((Lync.string :: any)._size):toBeNil ()
    end)
end)

return nil

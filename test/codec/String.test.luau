--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("String unbounded", function(): ()
    it("empty = 1 byte prefix", function(): ()
        local r, w = roundTrip(Lync.string, "")
        expect(r):toBe("")
        expect(w):toBe(1)
    end)
    it("1 char", function(): ()
        expect(roundTrip(Lync.string, "a")):toBe("a")
    end)
    it("short string", function(): ()
        expect(roundTrip(Lync.string, "hello")):toBe("hello")
    end)
    it("wire = 1 prefix + len for short", function(): ()
        local _, w = roundTrip(Lync.string, "hello")
        expect(w):toBe(6)
    end)
    it("100 chars", function(): ()
        local s = string.rep("x", 100)
        expect(roundTrip(Lync.string, s)):toBe(s)
    end)
    it("191 bytes = 1 byte prefix (max inline)", function(): ()
        local s = string.rep("x", 191)
        local _, w = roundTrip(Lync.string, s)
        expect(w):toBe(192)
    end)
    it("192 bytes = 2 byte varint prefix", function(): ()
        local s = string.rep("x", 192)
        local _, w = roundTrip(Lync.string, s)
        expect(w):toBe(194)
    end)
    it("255 bytes", function(): ()
        local s = string.rep("y", 255)
        expect(roundTrip(Lync.string, s)):toBe(s)
    end)
    it("1000 chars", function(): ()
        local s = string.rep("abcdefghij", 100)
        expect(roundTrip(Lync.string, s)):toBe(s)
    end)
    it("binary-safe (null bytes)", function(): ()
        local s = "abc\0def\0ghi"
        expect(roundTrip(Lync.string, s)):toBe(s)
    end)
    it("all byte values 0-255", function(): ()
        local parts = table.create(256)
        for i = 0, 255 do
            parts[i + 1] = string.char(i)
        end
        local s = table.concat(parts)
        expect(roundTrip(Lync.string, s)):toBe(s)
    end)
    it("_typeCheck = string", function(): ()
        expect((Lync.string :: any)._typeCheck):toBe("string")
    end)
end)

describe("String bounded via __call", function(): ()
    it("accepts within bound", function(): ()
        expect(roundTrip(Lync.string(10), "hello")):toBe("hello")
    end)
    it("accepts empty string", function(): ()
        expect(roundTrip(Lync.string(5), "")):toBe("")
    end)
    it("accepts exact bound", function(): ()
        expect(roundTrip(Lync.string(5), "abcde")):toBe("abcde")
    end)
    it("rejects exceeding bound on read", function(): ()
        local ch = Channel.create()
        Lync.string.write(ch, string.rep("x", 20))
        local buf = buffer.create(ch.cursor)
        buffer.copy(buf, 0, ch.buff, 0, ch.cursor)
        expect(function(): ()
            Lync.string(10).read(buf, 0, nil)
        end):toThrow("exceeds max")
    end)
    it("rejects maxLength = 0", function(): ()
        expect(function(): ()
            Lync.string(0)
        end):toThrow("positive")
    end)
    it("rejects maxLength < 0", function(): ()
        expect(function(): ()
            Lync.string(-1)
        end):toThrow("positive")
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe ("UDim.udim", function (): ()
    it ("round-trips zero", function (): ()
        local r = roundTrip (Lync.udim, UDim.new (0, 0))
        expect (r.Scale):toBe (0)
        expect (r.Offset):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.udim, UDim.new (0.5, 100))
        expect (r.Scale):toBeCloseTo (0.5)
        expect (r.Offset):toBe (100)
    end)
    it ("round-trips negative offset", function (): ()
        local r = roundTrip (Lync.udim, UDim.new (1, -50))
        expect (r.Scale):toBeCloseTo (1)
        expect (r.Offset):toBe (-50)
    end)
    it ("round-trips large offset", function (): ()
        local r = roundTrip (Lync.udim, UDim.new (0, 2147483647))
        expect (r.Offset):toBe (2147483647)
    end)
    it ("uses 8 bytes", function (): ()
        local _, w = roundTrip (Lync.udim, UDim.new (0.5, 10))
        expect (w):toBe (8)
    end)
    it ("_size is 8", function (): ()
        expect ((Lync.udim :: any)._size):toBe (8)
    end)
end)

describe ("UDim.udim2", function (): ()
    it ("round-trips zero", function (): ()
        local r = roundTrip (Lync.udim2, UDim2.new ())
        expect (r.X.Scale):toBe (0)
        expect (r.X.Offset):toBe (0)
        expect (r.Y.Scale):toBe (0)
        expect (r.Y.Offset):toBe (0)
    end)
    it ("round-trips positive", function (): ()
        local r = roundTrip (Lync.udim2, UDim2.new (UDim.new (0.5, 100), UDim.new (0.75, 200)))
        expect (r.X.Scale):toBeCloseTo (0.5)
        expect (r.X.Offset):toBe (100)
        expect (r.Y.Scale):toBeCloseTo (0.75)
        expect (r.Y.Offset):toBe (200)
    end)
    it ("round-trips negative offsets", function (): ()
        local r = roundTrip (Lync.udim2, UDim2.new (UDim.new (1, -10), UDim.new (0, -20)))
        expect (r.X.Scale):toBeCloseTo (1)
        expect (r.X.Offset):toBe (-10)
        expect (r.Y.Offset):toBe (-20)
    end)
    it ("uses 16 bytes", function (): ()
        local _, w = roundTrip (Lync.udim2, UDim2.new (UDim.new (1, 0), UDim.new (1, 0)))
        expect (w):toBe (16)
    end)
    it ("_size is 16", function (): ()
        expect ((Lync.udim2 :: any)._size):toBe (16)
    end)
end)

return nil

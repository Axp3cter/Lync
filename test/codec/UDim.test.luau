--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("udim", function(): ()
    it("zero", function(): ()
        local r = roundTrip(Lync.udim, UDim.new(0, 0))
        expect(r.Scale):toBeCloseTo(0)
        expect(r.Offset):toBe(0)
    end)
    it("positive", function(): ()
        local r = roundTrip(Lync.udim, UDim.new(0.5, 100))
        expect(r.Scale):toBeCloseTo(0.5)
        expect(r.Offset):toBe(100)
    end)
    it("8 bytes", function(): ()
        local _, w = roundTrip(Lync.udim, UDim.new(0, 0))
        expect(w):toBe(8)
    end)
end)

describe("udim2", function(): ()
    it("zero", function(): ()
        local r = roundTrip(Lync.udim2, UDim2.new())
        expect(r.X.Scale):toBeCloseTo(0)
        expect(r.Y.Scale):toBeCloseTo(0)
    end)
    it("full", function(): ()
        local r = roundTrip(Lync.udim2, UDim2.new(UDim.new(0.5, 10), UDim.new(1, 20)))
        expect(r.X.Scale):toBeCloseTo(0.5)
        expect(r.X.Offset):toBe(10)
        expect(r.Y.Scale):toBeCloseTo(1)
        expect(r.Y.Offset):toBe(20)
    end)
    it("16 bytes", function(): ()
        local _, w = roundTrip(Lync.udim2, UDim2.new())
        expect(w):toBe(16)
    end)
end)

return nil

--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.internal.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe ("unknown", function (): ()
    it ("string through sidecar", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "hello")
        expect (#ch.refs):toBe (1)
        expect (ch.refs[1]):toBe ("hello")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local val, consumed = Lync.unknown.read (buf, 0, ch.refs)
        expect (val):toBe ("hello")
        expect (consumed):toBe (2)
    end)
    it ("table through sidecar", function (): ()
        local ch = Channel.create ()
        local t = { a = 1 }
        Lync.unknown.write (ch, t)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local val, _ = Lync.unknown.read (buf, 0, ch.refs)
        expect (val):toBe (t)
    end)
    it ("instance through sidecar", function (): ()
        local ch = Channel.create ()
        local p = Instance.new ("Part")
        Lync.unknown.write (ch, p)
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        local val, _ = Lync.unknown.read (buf, 0, ch.refs)
        expect (val):toBe (p)
        p:Destroy ()
    end)
    it ("throws without refs", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "x")
        local buf = buffer.create (ch.cursor)
        buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
        expect (function (): ()
            Lync.unknown.read (buf, 0, nil)
        end):toThrow ("requires refs")
    end)
    it ("2 bytes per write", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, 1)
        expect (ch.cursor):toBe (2)
    end)
    it ("multiple values sequential", function (): ()
        local ch = Channel.create ()
        Lync.unknown.write (ch, "a")
        Lync.unknown.write (ch, "b")
        Lync.unknown.write (ch, "c")
        expect (#ch.refs):toBe (3)
        expect (ch.cursor):toBe (6)
    end)
end)

return nil

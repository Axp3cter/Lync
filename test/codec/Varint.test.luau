--!strict
--!optimize 2
local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Runner = require (script.Parent.Parent.Runner)
local Varint = require (script.Parent.Parent.Parent.codec.Varint)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

local function rt (value: number): (number, number)
    local ch = Channel.create ()
    Varint.write (ch, value)
    local buf = buffer.create (ch.cursor)
    buffer.copy (buf, 0, ch.buff, 0, ch.cursor)
    return Varint.read (buf, 0)
end

describe ("Varint round-trip", function (): ()
    it ("0 = 1 byte", function (): ()
        local v, b = rt (0)
        expect (v):toBe (0)
        expect (b):toBe (1)
    end)
    it ("1", function (): ()
        expect (rt (1)):toBe (1)
    end)
    it ("127 = 1 byte max", function (): ()
        local v, b = rt (127)
        expect (v):toBe (127)
        expect (b):toBe (1)
    end)
    it ("128 = 2 byte min", function (): ()
        local v, b = rt (128)
        expect (v):toBe (128)
        expect (b):toBe (2)
    end)
    it ("255", function (): ()
        expect (rt (255)):toBe (255)
    end)
    it ("256", function (): ()
        expect (rt (256)):toBe (256)
    end)
    it ("16383 = 2 byte max", function (): ()
        local v, b = rt (16383)
        expect (v):toBe (16383)
        expect (b):toBe (2)
    end)
    it ("16384 = 3 byte min", function (): ()
        local v, b = rt (16384)
        expect (v):toBe (16384)
        expect (b):toBe (3)
    end)
    it ("65535", function (): ()
        expect (rt (65535)):toBe (65535)
    end)
    it ("2097151 = 3 byte max", function (): ()
        local v, b = rt (2097151)
        expect (v):toBe (2097151)
        expect (b):toBe (3)
    end)
    it ("2097152 = 4 byte min", function (): ()
        local v, b = rt (2097152)
        expect (v):toBe (2097152)
        expect (b):toBe (4)
    end)
    it ("268435455 = 4 byte max", function (): ()
        local v, b = rt (268435455)
        expect (v):toBe (268435455)
        expect (b):toBe (4)
    end)
    it ("268435456 = 5 byte min", function (): ()
        local v, b = rt (268435456)
        expect (v):toBe (268435456)
        expect (b):toBe (5)
    end)
    it ("max u32", function (): ()
        expect (rt (4294967295)):toBe (4294967295)
    end)
end)

describe ("Varint validation", function (): ()
    it ("throws on -1", function (): ()
        expect (function (): ()
            local ch = Channel.create ()
            Varint.write (ch, -1)
        end):toThrow ("out of range")
    end)
    it ("throws on -1000", function (): ()
        expect (function (): ()
            local ch = Channel.create ()
            Varint.write (ch, -1000)
        end):toThrow ("out of range")
    end)
    it ("throws on u32+1", function (): ()
        expect (function (): ()
            local ch = Channel.create ()
            Varint.write (ch, 4294967296)
        end):toThrow ("out of range")
    end)
end)

describe ("Varint read safety", function (): ()
    it ("throws on empty buffer", function (): ()
        expect (function (): ()
            Varint.read (buffer.create (0), 0)
        end):toThrow ()
    end)
    it ("throws on truncated", function (): ()
        expect (function (): ()
            local buf = buffer.create (1)
            buffer.writeu8 (buf, 0, 0x80)
            Varint.read (buf, 0)
        end):toThrow ()
    end)
end)

describe ("Varint write size", function (): ()
    it ("0 writes 1 byte", function (): ()
        local ch = Channel.create ()
        Varint.write (ch, 0)
        expect (ch.cursor):toBe (1)
    end)
    it ("127 writes 1 byte", function (): ()
        local ch = Channel.create ()
        Varint.write (ch, 127)
        expect (ch.cursor):toBe (1)
    end)
    it ("128 writes 2 bytes", function (): ()
        local ch = Channel.create ()
        Varint.write (ch, 128)
        expect (ch.cursor):toBe (2)
    end)
    it ("max u32 writes 5 bytes", function (): ()
        local ch = Channel.create ()
        Varint.write (ch, 4294967295)
        expect (ch.cursor):toBe (5)
    end)
end)

return nil

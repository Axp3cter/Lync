--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("vec2", function(): ()
    it("origin", function(): ()
        local r = roundTrip(Lync.vec2, Vector2.zero)
        expect(r.X):toBe(0)
        expect(r.Y):toBe(0)
    end)
    it("positive", function(): ()
        local r = roundTrip(Lync.vec2, Vector2.new(1.5, 2.5))
        expect(r.X):toBeCloseTo(1.5)
        expect(r.Y):toBeCloseTo(2.5)
    end)
    it("negative", function(): ()
        local r = roundTrip(Lync.vec2, Vector2.new(-100, -200))
        expect(r.X):toBeCloseTo(-100)
        expect(r.Y):toBeCloseTo(-200)
    end)
    it("8 bytes", function(): ()
        local _, w = roundTrip(Lync.vec2, Vector2.one)
        expect(w):toBe(8)
    end)
    it("_size = 8", function(): ()
        expect((Lync.vec2 :: any)._size):toBe(8)
    end)
end)

describe("vec3", function(): ()
    it("origin", function(): ()
        local r = roundTrip(Lync.vec3, Vector3.zero)
        expect(r.X):toBe(0)
        expect(r.Y):toBe(0)
        expect(r.Z):toBe(0)
    end)
    it("positive", function(): ()
        local r = roundTrip(Lync.vec3, Vector3.new(10, 20, 30))
        expect(r.X):toBeCloseTo(10)
        expect(r.Y):toBeCloseTo(20)
        expect(r.Z):toBeCloseTo(30)
    end)
    it("mixed", function(): ()
        local r = roundTrip(Lync.vec3, Vector3.new(-1, 0, 1))
        expect(r.X):toBe(-1)
        expect(r.Y):toBe(0)
        expect(r.Z):toBe(1)
    end)
    it("12 bytes", function(): ()
        local _, w = roundTrip(Lync.vec3, Vector3.one)
        expect(w):toBe(12)
    end)
    it("_size = 12", function(): ()
        expect((Lync.vec3 :: any)._size):toBe(12)
    end)
end)

return nil

--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, roundTrip = Runner.describe, Runner.it, Runner.expect, Runner.roundTrip

describe("vec2 lossless", function(): ()
    it("_size = 8", function(): () expect((Lync.vec2 :: any)._size):toBe(8) end)
    it("positive values", function(): () local r = roundTrip(Lync.vec2, Vector2.new(1.5, -3.25)); expect(r.X):toBeCloseTo(1.5); expect(r.Y):toBeCloseTo(-3.25) end)
    it("zero", function(): () local r = roundTrip(Lync.vec2, Vector2.zero); expect(r.X):toBe(0); expect(r.Y):toBe(0) end)
    it("large values", function(): () local r = roundTrip(Lync.vec2, Vector2.new(10000, -10000)); expect(r.X):toBeCloseTo(10000); expect(r.Y):toBeCloseTo(-10000) end)
    it("has _directWrite", function(): () expect((Lync.vec2 :: any)._directWrite):toBeTruthy() end)
    it("_typeCheck = Vector2", function(): () expect((Lync.vec2 :: any)._typeCheck):toBe("Vector2") end)
    it("wire = 8 bytes", function(): () local _, w = roundTrip(Lync.vec2, Vector2.one); expect(w):toBe(8) end)
end)

describe("vec2 quantized via __call", function(): ()
    it("u8 per component", function(): ()
        local c = Lync.vec2(0, 100, 1)
        expect((c :: any)._size):toBe(2)
        local r = roundTrip(c, Vector2.new(50, 75))
        expect(r.X):toBeCloseTo(50, 1); expect(r.Y):toBeCloseTo(75, 1)
    end)
    it("u16 per component", function(): () expect((Lync.vec2(-1000, 1000, 0.1) :: any)._size):toBe(4) end)
    it("clamps out of range", function(): ()
        local c = Lync.vec2(0, 100, 1)
        local r = roundTrip(c, Vector2.new(200, -50))
        expect(r.X):toBeCloseTo(100, 1); expect(r.Y):toBeCloseTo(0, 1)
    end)
    it("min boundary", function(): ()
        local c = Lync.vec2(0, 100, 1)
        local r = roundTrip(c, Vector2.new(0, 0))
        expect(r.X):toBeCloseTo(0, 1); expect(r.Y):toBeCloseTo(0, 1)
    end)
    it("max boundary", function(): ()
        local c = Lync.vec2(0, 100, 1)
        local r = roundTrip(c, Vector2.new(100, 100))
        expect(r.X):toBeCloseTo(100, 1); expect(r.Y):toBeCloseTo(100, 1)
    end)
end)

describe("vec3 lossless", function(): ()
    it("_size = 12", function(): () expect((Lync.vec3 :: any)._size):toBe(12) end)
    it("positive values", function(): ()
        local r = roundTrip(Lync.vec3, Vector3.new(1, 2, 3))
        expect(r.X):toBeCloseTo(1); expect(r.Y):toBeCloseTo(2); expect(r.Z):toBeCloseTo(3)
    end)
    it("zero", function(): () local r = roundTrip(Lync.vec3, Vector3.zero); expect(r.X):toBe(0) end)
    it("negative", function(): ()
        local r = roundTrip(Lync.vec3, Vector3.new(-5, -10, -15))
        expect(r.X):toBeCloseTo(-5); expect(r.Y):toBeCloseTo(-10); expect(r.Z):toBeCloseTo(-15)
    end)
    it("_typeCheck = Vector3", function(): () expect((Lync.vec3 :: any)._typeCheck):toBe("Vector3") end)
end)

describe("vec3 quantized via __call", function(): ()
    it("u8 per component = 3 bytes", function(): ()
        local c = Lync.vec3(0, 100, 1)
        expect((c :: any)._size):toBe(3)
        local r = roundTrip(c, Vector3.new(25, 50, 75))
        expect(r.X):toBeCloseTo(25, 1); expect(r.Y):toBeCloseTo(50, 1); expect(r.Z):toBeCloseTo(75, 1)
    end)
    it("u16 per component = 6 bytes", function(): () expect((Lync.vec3(-1000, 1000, 0.1) :: any)._size):toBe(6) end)
    it("negative range", function(): ()
        local c = Lync.vec3(-100, 100, 1)
        local r = roundTrip(c, Vector3.new(-50, 0, 50))
        expect(r.X):toBeCloseTo(-50, 1); expect(r.Y):toBeCloseTo(0, 1); expect(r.Z):toBeCloseTo(50, 1)
    end)
end)

return nil

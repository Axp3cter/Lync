--!strict
--!optimize 2
local Runner  = require(script.Parent.Parent.Runner)
local Channel = require(script.Parent.Parent.Parent.core.Channel)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Channel.create", function(): ()
    it("initial size 1024",  function(): () local ch = Channel.create(); expect(ch.size):toBe(1024) end)
    it("cursor at 0",        function(): () expect(Channel.create().cursor):toBe(0) end)
    it("empty refs",         function(): () expect(#Channel.create().refs):toBe(0) end)
    it("lastId = -1",        function(): () expect(Channel.create().lastId):toBe(-1) end)
    it("batchCount = 0",     function(): () expect(Channel.create().batchCount):toBe(0) end)
    it("prevDump nil",       function(): () expect(Channel.create().prevDump):toBeNil() end)
    it("empty deltas",       function(): () expect(next(Channel.create().deltas)):toBeNil() end)
end)

describe("Channel.alloc", function(): ()
    it("no-op when space available",  function(): () local ch = Channel.create(); Channel.alloc(ch, 512); expect(ch.size):toBe(1024) end)
    it("grows when needed",           function(): () local ch = Channel.create(); Channel.alloc(ch, 2000); expect(ch.size >= 2000):toBe(true) end)
    it("grows by doubling",           function(): () local ch = Channel.create(); Channel.alloc(ch, 1025); expect(ch.size):toBe(2048) end)
    it("preserves data on grow",      function(): () local ch = Channel.create(); buffer.writeu8(ch.buff, 0, 0xAB); ch.cursor = 1; Channel.alloc(ch, 2000); expect(buffer.readu8(ch.buff, 0)):toBe(0xAB) end)
    it("throws on >65536",            function(): () expect(function(): () Channel.alloc(Channel.create(), 65537) end):toThrow("Buffer overflow") end)
    it("allows exactly 65536",        function(): () expect(function(): () Channel.alloc(Channel.create(), 65536) end).never:toThrow() end)
end)

describe("Channel.writeBatch + seal", function(): ()
    it("writes id + count placeholder + payload", function(): ()
        local ch = Channel.create()
        local codec = { write = function(c: any, v: any): () Channel.alloc(c, 1); buffer.writeu8(c.buff, c.cursor, v); c.cursor += 1 end }
        Channel.writeBatch(ch, 5, codec, 0xAA)
        Channel.writeBatch(ch, 5, codec, 0xBB)
        Channel.seal(ch)
        expect(ch.cursor):toBe(5) -- 1 id + 2 count + 2 payload
        expect(buffer.readu8(ch.buff, 0)):toBe(5)
        expect(buffer.readu16(ch.buff, 1)):toBe(2)
        expect(buffer.readu8(ch.buff, 3)):toBe(0xAA)
        expect(buffer.readu8(ch.buff, 4)):toBe(0xBB)
    end)
    it("different IDs get separate headers", function(): ()
        local ch = Channel.create()
        local codec = { write = function(c: any, _: any): () Channel.alloc(c, 1); buffer.writeu8(c.buff, c.cursor, 0xFF); c.cursor += 1 end }
        Channel.writeBatch(ch, 1, codec, nil)
        Channel.writeBatch(ch, 2, codec, nil)
        Channel.seal(ch)
        -- Two headers: (1+2+1) + (1+2+1) = 8
        expect(ch.cursor):toBe(8)
        expect(buffer.readu8(ch.buff, 0)):toBe(1)
        expect(buffer.readu16(ch.buff, 1)):toBe(1)
        expect(buffer.readu8(ch.buff, 4)):toBe(2)
        expect(buffer.readu16(ch.buff, 5)):toBe(1)
    end)
    it("seal is idempotent", function(): ()
        local ch = Channel.create()
        Channel.seal(ch); Channel.seal(ch) -- no-op on empty
        expect(ch.cursor):toBe(0)
    end)
end)

describe("Channel.writeBatchRaw", function(): ()
    it("copies bytes", function(): ()
        local ch = Channel.create()
        local src = buffer.create(3); buffer.writeu8(src, 0, 0xAA); buffer.writeu8(src, 1, 0xBB); buffer.writeu8(src, 2, 0xCC)
        Channel.writeBatchRaw(ch, 1, src, 3, nil)
        Channel.seal(ch)
        expect(ch.cursor):toBe(6) -- header(3) + payload(3)
    end)
    it("appends refs", function(): ()
        local ch = Channel.create(); local p = Instance.new("Part")
        Channel.writeBatchRaw(ch, 1, buffer.create(0), 0, { p })
        expect(ch.refs[1]):toBe(p); p:Destroy()
    end)
    it("zero-length raw is just header", function(): ()
        local ch = Channel.create()
        Channel.writeBatchRaw(ch, 1, buffer.create(0), 0, nil)
        Channel.seal(ch)
        expect(ch.cursor):toBe(3)
    end)
end)

describe("Channel.dump", function(): ()
    it("exact copy",    function(): () local ch = Channel.create(); buffer.writeu32(ch.buff, 0, 0xDEADBEEF); ch.cursor = 4; local b, r = Channel.dump(ch); expect(buffer.len(b)):toBe(4); expect(buffer.readu32(b, 0)):toBe(0xDEADBEEF); expect(r):toBeNil() end)
    it("clones refs",   function(): () local ch = Channel.create(); local p = Instance.new("Part"); table.insert(ch.refs, p); ch.cursor = 1; local _, r = Channel.dump(ch); expect(r).never:toBeNil(); expect((r :: any)[1]):toBe(p); p:Destroy() end)
    it("dump is a copy, not alias", function(): ()
        local ch = Channel.create(); buffer.writeu8(ch.buff, 0, 42); ch.cursor = 1
        local b = Channel.dump(ch)
        buffer.writeu8(ch.buff, 0, 99)
        expect(buffer.readu8(b, 0)):toBe(42) -- original unchanged
    end)
end)

describe("Channel.xorApply", function(): ()
    it("nil previous = identity",   function(): () local c = buffer.create(4); buffer.writeu32(c, 0, 0xAABBCCDD); expect(buffer.readu32(Channel.xorApply(c, nil), 0)):toBe(0xAABBCCDD) end)
    it("XORs overlapping bytes",     function(): () local c = buffer.create(4); local p = buffer.create(4); buffer.writeu32(c, 0, 0xFF00FF00); buffer.writeu32(p, 0, 0x00FF00FF); expect(buffer.readu32(Channel.xorApply(c, p), 0)):toBe(0xFFFFFFFF) end)
    it("same data XORs to zero",    function(): () local c = buffer.create(4); buffer.writeu32(c, 0, 0xDEAD); local r = Channel.xorApply(c, c); expect(buffer.readu32(r, 0)):toBe(0) end)
    it("copies tail if current longer", function(): () local c = buffer.create(6); local p = buffer.create(2); buffer.writeu8(c, 4, 0xCC); local r = Channel.xorApply(c, p); expect(buffer.readu8(r, 4)):toBe(0xCC) end)
    it("empty previous = identity", function(): () local c = buffer.create(4); buffer.writeu32(c, 0, 123); expect(buffer.readu32(Channel.xorApply(c, buffer.create(0)), 0)):toBe(123) end)
end)

describe("Channel.reset", function(): ()
    it("zeroes cursor",   function(): () local ch = Channel.create(); ch.cursor = 100; Channel.reset(ch); expect(ch.cursor):toBe(0) end)
    it("clears refs",     function(): () local ch = Channel.create(); table.insert(ch.refs, Instance.new("Part")); Channel.reset(ch); expect(#ch.refs):toBe(0) end)
    it("resets lastId",   function(): () local ch = Channel.create(); ch.lastId = 5; Channel.reset(ch); expect(ch.lastId):toBe(-1) end)
    it("resets batchCount", function(): () local ch = Channel.create(); ch.batchCount = 10; Channel.reset(ch); expect(ch.batchCount):toBe(0) end)
end)

return nil

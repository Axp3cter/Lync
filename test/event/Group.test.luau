--!strict
--!optimize 2
local Group = require (script.Parent.Parent.Parent.event.Group)
local Runner = require (script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer =
    Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe ("Group create+destroy", function (): ()
    it ("creates and destroys", function (): ()
        Group.create ("__g_life")
        expect (function (): ()
            Group.destroy ("__g_life")
        end).never:toThrow ()
    end)
    it ("throws duplicate", function (): ()
        Group.create ("__g_dup")
        expect (function (): ()
            Group.create ("__g_dup")
        end):toThrow ("already exists")
        Group.destroy ("__g_dup")
    end)
    it ("throws nonexistent", function (): ()
        expect (function (): ()
            Group.destroy ("__g_nope")
        end):toThrow ("does not exist")
    end)
end)

describe ("Group add+remove+has", function (): ()
    it ("adds and reports", function (): ()
        Group.create ("__g_m")
        local a, b = fakePlayer ("A", 1), fakePlayer ("B", 2)
        expect (Group.add ("__g_m", a)):toBe (true)
        expect (Group.add ("__g_m", b)):toBe (true)
        expect (Group.count ("__g_m")):toBe (2)
        expect (Group.has ("__g_m", a)):toBe (true)
        Group.destroy ("__g_m")
    end)
    it ("duplicate add = false", function (): ()
        Group.create ("__g_da")
        local p = fakePlayer ("A", 1)
        expect (Group.add ("__g_da", p)):toBe (true)
        expect (Group.add ("__g_da", p)):toBe (false)
        Group.destroy ("__g_da")
    end)
    it ("removes", function (): ()
        Group.create ("__g_rm")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_rm", p)
        Group.remove ("__g_rm", p)
        expect (Group.count ("__g_rm")):toBe (0)
        expect (Group.has ("__g_rm", p)):toBe (false)
        Group.destroy ("__g_rm")
    end)
    it ("throws add nonexistent", function (): ()
        expect (function (): ()
            Group.add ("__g_ghost", fakePlayer ("A", 1))
        end):toThrow ("does not exist")
    end)
    it ("throws remove nonexistent", function (): ()
        expect (function (): ()
            Group.remove ("__g_ghost2", fakePlayer ("A", 1))
        end):toThrow ("does not exist")
    end)
    it ("throws has nonexistent", function (): ()
        expect (function (): ()
            Group.has ("__g_ghost3", fakePlayer ("A", 1))
        end):toThrow ("does not exist")
    end)
end)

describe ("Group getSet", function (): ()
    it ("returns set", function (): ()
        Group.create ("__g_gs")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_gs", p)
        expect (Group.getSet ("__g_gs")[p]):toBe (true)
        Group.destroy ("__g_gs")
    end)
    it ("throws nonexistent", function (): ()
        expect (function (): ()
            Group.getSet ("__g_gs_nope")
        end):toThrow ("does not exist")
    end)
end)

describe ("Group forEach", function (): ()
    it ("iterates all", function (): ()
        Group.create ("__g_fe")
        Group.add ("__g_fe", fakePlayer ("A", 1))
        Group.add ("__g_fe", fakePlayer ("B", 2))
        expect (Group.count ("__g_fe")):toBe (2)
        Group.destroy ("__g_fe")
    end)
    it ("throws nonexistent", function (): ()
        expect (function (): ()
            Group.forEach ("__g_fe_nope", function (): () end)
        end):toThrow ("does not exist")
    end)
end)

describe ("Group destroy cleanup", function (): ()
    it ("clears reverse index", function (): ()
        Group.create ("__g_dc")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_dc", p)
        Group.destroy ("__g_dc")
        Group.create ("__g_dc")
        expect (Group.has ("__g_dc", p)):toBe (false)
        Group.destroy ("__g_dc")
    end)
end)

describe ("Group multi-membership", function (): ()
    it ("player in 2 groups, destroy one", function (): ()
        Group.create ("__g_ma")
        Group.create ("__g_mb")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_ma", p)
        Group.add ("__g_mb", p)
        Group.destroy ("__g_ma")
        expect (Group.has ("__g_mb", p)):toBe (true)
        Group.destroy ("__g_mb")
    end)
end)

describe ("Group.count", function (): ()
    it ("0 on empty", function (): ()
        Group.create ("__g_c0")
        expect (Group.count ("__g_c0")):toBe (0)
        Group.destroy ("__g_c0")
    end)
    it ("increments on add", function (): ()
        Group.create ("__g_ci")
        Group.add ("__g_ci", fakePlayer ("A", 1))
        Group.add ("__g_ci", fakePlayer ("B", 2))
        expect (Group.count ("__g_ci")):toBe (2)
        Group.destroy ("__g_ci")
    end)
    it ("decrements on remove", function (): ()
        Group.create ("__g_cd")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_cd", p)
        Group.add ("__g_cd", fakePlayer ("B", 2))
        Group.remove ("__g_cd", p)
        expect (Group.count ("__g_cd")):toBe (1)
        Group.destroy ("__g_cd")
    end)
    it ("duplicate add doesn't increment", function (): ()
        Group.create ("__g_cda")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_cda", p)
        Group.add ("__g_cda", p)
        expect (Group.count ("__g_cda")):toBe (1)
        Group.destroy ("__g_cda")
    end)
    it ("remove of absent doesn't decrement", function (): ()
        Group.create ("__g_cra")
        Group.add ("__g_cra", fakePlayer ("A", 1))
        Group.remove ("__g_cra", fakePlayer ("B", 2))
        expect (Group.count ("__g_cra")):toBe (1)
        Group.destroy ("__g_cra")
    end)
    it ("throws nonexistent", function (): ()
        expect (function (): ()
            Group.count ("__g_cnope")
        end):toThrow ("does not exist")
    end)
end)

describe ("Group.remove returns boolean", function (): ()
    it ("true when present", function (): ()
        Group.create ("__g_rb")
        local p = fakePlayer ("A", 1)
        Group.add ("__g_rb", p)
        expect (Group.remove ("__g_rb", p)):toBe (true)
        Group.destroy ("__g_rb")
    end)
    it ("false when absent", function (): ()
        Group.create ("__g_rb2")
        expect (Group.remove ("__g_rb2", fakePlayer ("A", 1))):toBe (false)
        Group.destroy ("__g_rb2")
    end)
end)

return nil

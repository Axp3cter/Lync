--!strict
--!optimize 2
local Baseline = require(script.Parent.Parent.Parent.internal.Baseline)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Baseline: get/set cache", function(): ()
    it("nil when no cache", function(): ()
        Baseline.setReadKey("__bl_none"); expect(Baseline.getCache(99999)):toBeNil()
    end)
    it("set then get returns value", function(): ()
        Baseline.setReadKey("__bl_set"); Baseline.setCache(88888, { hp = 100 })
        expect(Baseline.getCache(88888).hp):toBe(100)
    end)
    it("overwrite replaces", function(): ()
        Baseline.setReadKey("__bl_ow"); Baseline.setCache(77770, "old")
        Baseline.setCache(77770, "new"); expect(Baseline.getCache(77770)):toBe("new")
    end)
end)

describe("Baseline: per-player isolation", function(): ()
    it("different keys = independent", function(): ()
        Baseline.setReadKey("__pA"); Baseline.setCache(66660, "A")
        Baseline.setReadKey("__pB"); Baseline.setCache(66660, "B")
        Baseline.setReadKey("__pA"); expect(Baseline.getCache(66660)):toBe("A")
        Baseline.setReadKey("__pB"); expect(Baseline.getCache(66660)):toBe("B")
    end)
    it("key A cannot see key B data", function(): ()
        Baseline.setReadKey("__pC"); Baseline.setCache(55550, "C")
        Baseline.setReadKey("__pD"); expect(Baseline.getCache(55550)):toBeNil()
    end)
end)

describe("Baseline: clearPlayer", function(): ()
    it("removes all caches for key", function(): ()
        Baseline.setReadKey("__pCl"); Baseline.setCache(44440, "d1"); Baseline.setCache(44441, "d2")
        Baseline.clearPlayer("__pCl")
        Baseline.setReadKey("__pCl"); expect(Baseline.getCache(44440)):toBeNil(); expect(Baseline.getCache(44441)):toBeNil()
    end)
    it("does not affect other keys", function(): ()
        Baseline.setReadKey("__pE"); Baseline.setCache(33330, "E")
        Baseline.setReadKey("__pF"); Baseline.setCache(33330, "F")
        Baseline.clearPlayer("__pE")
        Baseline.setReadKey("__pF"); expect(Baseline.getCache(33330)):toBe("F")
    end)
end)

describe("Baseline: hasDelta flag", function(): ()
    it("markHasDelta sets true", function(): () Baseline.markHasDelta(); expect(Baseline.hasDelta()):toBe(true) end)
end)

return nil

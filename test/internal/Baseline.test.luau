--!strict
--!optimize 2
local Baseline = require(script.Parent.Parent.Parent.internal.Baseline)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer =
    Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe("Baseline get/set", function(): ()
    it("nil for unset", function(): ()
        Baseline.setReadKey(false)
        expect(Baseline.getCache(99999)):toBeNil()
    end)
    it("returns after set", function(): ()
        Baseline.setReadKey(false)
        Baseline.setCache(10000, { hp = 50 })
        expect((Baseline.getCache(10000) :: any).hp):toBe(50)
    end)
    it("overwrites", function(): ()
        Baseline.setReadKey(false)
        Baseline.setCache(10001, "first")
        Baseline.setCache(10001, "second")
        expect(Baseline.getCache(10001)):toBe("second")
    end)
end)

describe("Baseline source isolation", function(): ()
    it("different keys isolated", function(): ()
        local p1 = fakePlayer("P1", 1001)
        local p2 = fakePlayer("P2", 1002)
        Baseline.setReadKey(p1)
        Baseline.setCache(10002, "p1data")
        Baseline.setReadKey(p2)
        expect(Baseline.getCache(10002)):toBeNil()
    end)
    it("false key works as client sentinel", function(): ()
        Baseline.setReadKey(false)
        Baseline.setCache(10003, "client")
        expect(Baseline.getCache(10003)):toBe("client")
    end)
end)

describe("Baseline.clearSource", function(): ()
    it("removes all caches for source", function(): ()
        local p = fakePlayer("CL", 1010)
        Baseline.setReadKey(p)
        Baseline.setCache(10004, "a")
        Baseline.setCache(10005, "b")
        Baseline.clearSource(p)
        Baseline.setReadKey(p)
        expect(Baseline.getCache(10004)):toBeNil()
        expect(Baseline.getCache(10005)):toBeNil()
    end)
    it("doesn't affect other sources", function(): ()
        local p1 = fakePlayer("C1", 1011)
        local p2 = fakePlayer("C2", 1012)
        Baseline.setReadKey(p1)
        Baseline.setCache(10006, "p1")
        Baseline.setReadKey(p2)
        Baseline.setCache(10006, "p2")
        Baseline.clearSource(p1)
        Baseline.setReadKey(p2)
        expect(Baseline.getCache(10006)):toBe("p2")
    end)
    it("nonexistent source safe", function(): ()
        Baseline.clearSource(fakePlayer("X", 9999))
    end)
end)

return nil

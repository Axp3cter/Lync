--!strict
--!optimize 2
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

local mockReg = Channel.mockReg

describe("Channel.create", function(): ()
    it("size 1024", function(): ()
        expect(Channel.create().size):toBe(1024)
    end)
    it("cursor 0", function(): ()
        expect(Channel.create().cursor):toBe(0)
    end)
    it("empty refs", function(): ()
        expect(#Channel.create().refs):toBe(0)
    end)
    it("lastId -1", function(): ()
        expect(Channel.create().lastId):toBe(-1)
    end)
    it("itemCount 0", function(): ()
        expect(Channel.create().itemCount):toBe(0)
    end)
    it("prevDump nil", function(): ()
        expect(Channel.create().prevDump):toBeNil()
    end)
end)

describe("Channel.alloc", function(): ()
    it("no-op when enough space", function(): ()
        local ch = Channel.create()
        local s = ch.size
        Channel.alloc(ch, 10)
        expect(ch.size):toBe(s)
    end)
    it("grows when needed", function(): ()
        local ch = Channel.create()
        ch.cursor = 1020
        Channel.alloc(ch, 100)
        expect(ch.size):toBeGreaterThan(1024)
    end)
    it("preserves data", function(): ()
        local ch = Channel.create()
        buffer.writeu8(ch.buff, 0, 42)
        ch.cursor = 1020
        Channel.alloc(ch, 100)
        expect(buffer.readu8(ch.buff, 0)):toBe(42)
    end)
    it("throws overflow", function(): ()
        expect(function(): ()
            local ch = Channel.create()
            ch.cursor = 262140
            ch.size = 262144
            Channel.alloc(ch, 262144)
        end):toThrow("overflow")
    end)
end)

describe("Channel.writeBatch", function(): ()
    it("advances cursor", function(): ()
        local ch = Channel.create()
        Channel.writeBatch(ch, mockReg(1, "t", Lync.u8), 42)
        expect(ch.cursor):toBeGreaterThan(0)
    end)
    it("same ID increments itemCount", function(): ()
        local ch = Channel.create()
        local reg = mockReg(1, "a", Lync.u8)
        Channel.writeBatch(ch, reg, 10)
        Channel.writeBatch(ch, reg, 20)
        expect(ch.itemCount):toBe(2)
    end)
end)

describe("Channel.sealAndDump", function(): ()
    it("empty is zero length", function(): ()
        local raw, refs = Channel.sealAndDump(Channel.create())
        expect(buffer.len(raw)):toBe(0)
        expect(#refs):toBe(0)
    end)
    it("non-empty is positive length", function(): ()
        local ch = Channel.create()
        Channel.writeBatch(ch, mockReg(1, "t", Lync.u8), 255)
        local raw, _ = Channel.sealAndDump(ch)
        expect(buffer.len(raw)):toBeGreaterThan(0)
    end)
end)

describe("Channel.xorApply", function(): ()
    it("nil previous = identity", function(): ()
        local src = buffer.create(4)
        buffer.writeu32(src, 0, 0x12345678)
        expect(buffer.readu32(Channel.xorApply(src, nil), 0)):toBe(0x12345678)
    end)
    it("same data = zero", function(): ()
        local a = buffer.create(4)
        buffer.writeu32(a, 0, 0xDEADBEEF)
        local b = buffer.create(4)
        buffer.writeu32(b, 0, 0xDEADBEEF)
        expect(buffer.readu32(Channel.xorApply(a, b), 0)):toBe(0)
    end)
    it("XOR inverse", function(): ()
        local a = buffer.create(4)
        buffer.writeu32(a, 0, 0xFF00FF00)
        local b = buffer.create(4)
        buffer.writeu32(b, 0, 0x00FF00FF)
        expect(buffer.readu32(Channel.xorApply(a, b), 0)):toBe(0xFFFFFFFF)
    end)
    it("longer current copies tail", function(): ()
        local a = buffer.create(8)
        buffer.writeu32(a, 4, 0xAB)
        local b = buffer.create(4)
        expect(buffer.readu32(Channel.xorApply(a, b), 4)):toBe(0xAB)
    end)
end)

describe("Channel.reset", function(): ()
    it("zeroes all state", function(): ()
        local ch = Channel.create()
        Channel.writeBatch(ch, mockReg(1, "t", Lync.u8), 1)
        table.insert(ch.refs, Instance.new("Part"))
        Channel.reset(ch)
        expect(ch.cursor):toBe(0)
        expect(ch.lastId):toBe(-1)
        expect(ch.itemCount):toBe(0)
        expect(#ch.refs):toBe(0)
    end)
end)

describe("Channel.setMaxSize / getMaxSize", function(): ()
    it("set and get", function(): ()
        local old = Channel.getMaxSize()
        Channel.setMaxSize(1024 * 1024)
        expect(Channel.getMaxSize()):toBe(1024 * 1024)
        Channel.setMaxSize(old)
    end)
end)

return nil

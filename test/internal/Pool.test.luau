--!strict
--!optimize 2
local Pool = require(script.Parent.Parent.Parent.internal.Pool)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Pool.acquire", function(): ()
    it("cursor 0", function(): ()
        expect(Pool.acquire().cursor):toBe(0)
    end)
    it("size 1024", function(): ()
        expect(Pool.acquire().size):toBe(1024)
    end)
    it("distinct", function(): ()
        local a = Pool.acquire()
        local b = Pool.acquire()
        expect(a ~= b):toBe(true)
        Pool.release(a)
        Pool.release(b)
    end)
end)

describe("Pool.release + reacquire", function(): ()
    it("resets cursor", function(): ()
        local ch = Pool.acquire()
        ch.cursor = 500
        Pool.release(ch)
        expect(Pool.acquire().cursor):toBe(0)
    end)
    it("clears refs", function(): ()
        local ch = Pool.acquire()
        table.insert(ch.refs, Instance.new("Part"))
        Pool.release(ch)
        expect(#Pool.acquire().refs):toBe(0)
    end)
end)

describe("Pool LIFO", function(): ()
    it("last released = first acquired", function(): ()
        local a = Pool.acquire()
        local b = Pool.acquire()
        Pool.release(b)
        Pool.release(a)
        local c = Pool.acquire()
        expect(c):toBe(a)
        Pool.release(c)
        Pool.release(b)
    end)
end)

describe("Pool.size", function(): ()
    it("returns count", function(): ()
        local initial = Pool.size()
        local ch = Pool.acquire()
        Pool.release(ch)
        expect(Pool.size()):toBeGreaterThan(initial - 1)
    end)
end)

describe("Pool.setMaxSize / getMaxSize", function(): ()
    it("set and get", function(): ()
        local old = Pool.getMaxSize()
        Pool.setMaxSize(100)
        expect(Pool.getMaxSize()):toBe(100)
        Pool.setMaxSize(old)
    end)
end)

return nil

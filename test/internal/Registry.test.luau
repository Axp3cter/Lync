--!strict
--!optimize 2
local Lync = require(script.Parent.Parent.Parent)
local Registry = require(script.Parent.Parent.Parent.internal.Registry)
local Runner = require(script.Parent.Parent.Runner)
local Signal = require(script.Parent.Parent.Parent.api.Signal)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Registry.register", function(): ()
    local sig = Signal.create()
    local r = Registry.register("__rt1", Lync.u8, false, sig, nil, nil)
    it("stores name", function(): ()
        expect(r.name):toBe("__rt1")
    end)
    it("stores baseName", function(): ()
        expect(r.baseName):toBe("__rt1")
    end)
    it("stores isUnreliable", function(): ()
        expect(r.isUnreliable):toBe(false)
    end)
    it("kind = PACKET", function(): ()
        expect(r.kind):toBe(Registry.KIND_PACKET)
    end)
    it("stores codec", function(): ()
        expect(r.codec):toBe(Lync.u8)
    end)
    it("needsGate false", function(): ()
        expect(r.needsGate):toBe(false)
    end)
    it("auto-increments id", function(): ()
        local r2 = Registry.register("__rt1b", Lync.u8, false, Signal.create(), nil, nil)
        expect(r2.id):toBeGreaterThan(r.id)
    end)
end)

describe("Registry KIND constants", function(): ()
    it("PACKET = 0", function(): ()
        expect(Registry.KIND_PACKET):toBe(0)
    end)
    it("REQUEST = 1", function(): ()
        expect(Registry.KIND_REQUEST):toBe(1)
    end)
    it("RESPONSE = 2", function(): ()
        expect(Registry.KIND_RESPONSE):toBe(2)
    end)
end)

describe("Registry.get / getByName", function(): ()
    local sig = Signal.create()
    local r = Registry.register("__rt2", Lync.u8, false, sig, nil, nil)
    it("by ID", function(): ()
        expect(Registry.get(r.id)):toBe(r)
    end)
    it("by name", function(): ()
        expect(Registry.getByName("__rt2")):toBe(r)
    end)
    it("nil bad ID", function(): ()
        expect(Registry.get(99999)):toBeNil()
    end)
    it("nil bad name", function(): ()
        expect(Registry.getByName("__nope")):toBeNil()
    end)
end)

describe("Registry.registerQueryPair", function(): ()
    local req, resp = Registry.registerQueryPair(
        "__rq1",
        Lync.u8,
        Lync.u16,
        Signal.create(),
        Signal.create(),
        nil,
        nil
    )
    it("req kind", function(): ()
        expect(req.kind):toBe(Registry.KIND_REQUEST)
    end)
    it("resp kind", function(): ()
        expect(resp.kind):toBe(Registry.KIND_RESPONSE)
    end)
    it("linked partners", function(): ()
        expect(req.partner):toBe(resp.id)
        expect(resp.partner):toBe(req.id)
    end)
    it("names suffixed", function(): ()
        expect(req.name):toBe("__rq1:req")
        expect(resp.name):toBe("__rq1:resp")
    end)
    it("baseName shared", function(): ()
        expect(req.baseName):toBe("__rq1")
        expect(resp.baseName):toBe("__rq1")
    end)
end)

describe("Registry needsGate", function(): ()
    it("true with rateLimit", function(): ()
        local r =
            Registry.register("__rg1", Lync.u8, false, Signal.create(), { maxPerSecond = 10 }, nil)
        expect(r.needsGate):toBe(true)
    end)
    it("true with validate", function(): ()
        local r = Registry.register("__rg2", Lync.u8, false, Signal.create(), nil, function()
            return true
        end)
        expect(r.needsGate):toBe(true)
    end)
end)

describe("Registry validation", function(): ()
    it("throws duplicate", function(): ()
        expect(function(): ()
            Registry.register("__rdup", Lync.u8, false, Signal.create(), nil, nil)
            Registry.register("__rdup", Lync.u8, false, Signal.create(), nil, nil)
        end):toThrow("Duplicate")
    end)
end)

return nil

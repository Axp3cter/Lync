--!strict
--!optimize 2
local Registry = require(script.Parent.Parent.Parent.internal.Registry)
local Channel = require(script.Parent.Parent.Parent.internal.Channel)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect = Runner.describe, Runner.it, Runner.expect

describe("Registry: sequential IDs", function(): ()
    it("first ID > 0", function(): ()
        local before = Registry.count()
        local openFn = Channel.resolveOpenFn(Channel.TS_NONE, "__rseq1")
        local reg = Registry.register("__rseq1", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        expect(reg.id):toBeGreaterThan(0)
    end)
    it("count increments", function(): ()
        local before = Registry.count()
        local openFn = Channel.resolveOpenFn(Channel.TS_NONE, "__rseq2")
        Registry.register("__rseq2", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        expect(Registry.count()):toBe(before + 1)
    end)
    it("IDs are sequential", function(): ()
        local openA = Channel.resolveOpenFn(Channel.TS_NONE, "__rseq3a")
        local openB = Channel.resolveOpenFn(Channel.TS_NONE, "__rseq3b")
        local a = Registry.register("__rseq3a", 0, Lync.int(0, 255), false, nil, false, 1, 0, openA, nil, nil, nil)
        local b = Registry.register("__rseq3b", 0, Lync.int(0, 255), false, nil, false, 1, 0, openB, nil, nil, nil)
        expect(b.id):toBe(a.id + 1)
    end)
end)

describe("Registry: lookup", function(): ()
    it("get by ID", function(): ()
        local openFn = Channel.resolveOpenFn(Channel.TS_NONE, "__rget")
        local reg = Registry.register("__rget", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        expect(Registry.get(reg.id)):toBeTruthy()
        expect((Registry.get(reg.id) :: any).name):toBe("__rget")
    end)
    it("getByName", function(): ()
        local openFn = Channel.resolveOpenFn(Channel.TS_NONE, "__rname")
        Registry.register("__rname", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        expect(Registry.getByName("__rname")):toBeTruthy()
    end)
    it("get unknown ID = nil", function(): () expect(Registry.get(9999)):toBeNil() end)
    it("getByName unknown = nil", function(): () expect(Registry.getByName("__nope")):toBeNil() end)
end)

describe("Registry: duplicate name errors", function(): ()
    it("throws", function(): ()
        local openFn = Channel.resolveOpenFn(Channel.TS_NONE, "__rdup")
        Registry.register("__rdup", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        expect(function(): ()
            Registry.register("__rdup", 0, Lync.int(0, 255), false, nil, false, 1, 0, openFn, nil, nil, nil)
        end):toThrow("duplicate")
    end)
end)

describe("Registry: all()", function(): ()
    it("returns non-empty list", function(): () expect(#Registry.all()):toBeGreaterThan(0) end)
end)

describe("Registry: kind constants", function(): ()
    it("KIND_PACKET = 0", function(): () expect(Registry.KIND_PACKET):toBe(0) end)
    it("KIND_REQUEST = 1", function(): () expect(Registry.KIND_REQUEST):toBe(1) end)
    it("KIND_RESPONSE = 2", function(): () expect(Registry.KIND_RESPONSE):toBe(2) end)
end)

return nil

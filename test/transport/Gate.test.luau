--!strict
--!optimize 2
local Gate = require(script.Parent.Parent.Parent.transport.Gate)
local Lync = require(script.Parent.Parent.Parent)
local Runner = require(script.Parent.Parent.Runner)
local describe, it, expect, fakePlayer = Runner.describe, Runner.it, Runner.expect, Runner.fakePlayer

describe("Gate rate limit: token bucket", function(): ()
    it("allows burst tokens", function(): ()
        local reg: any = { id = 50001, rateLimit = { maxPerSecond = 2, burst = 3 } }
        local p = fakePlayer("RL1", 5001)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        Gate.clearPlayer(p)
    end)
    it("rejects after burst exhausted", function(): ()
        local reg: any = { id = 50002, rateLimit = { maxPerSecond = 2, burst = 2 } }
        local p = fakePlayer("RL2", 5002)
        Gate.checkRateLimit(reg, p); Gate.checkRateLimit(reg, p)
        expect(Gate.checkRateLimit(reg, p)):toBe(false)
        Gate.clearPlayer(p)
    end)
    it("default burst = 1 when omitted", function(): ()
        local reg: any = { id = 50003, rateLimit = { maxPerSecond = 10 } }
        local p = fakePlayer("RL3", 5003)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        expect(Gate.checkRateLimit(reg, p)):toBe(false)
        Gate.clearPlayer(p)
    end)
    it("no rate limit = always pass", function(): ()
        local reg: any = { id = 50004, rateLimit = nil }
        local p = fakePlayer("RL4", 5004)
        for _ = 1, 100 do
            expect(Gate.checkRateLimit(reg, p)):toBe(true)
        end
        Gate.clearPlayer(p)
    end)
end)

describe("Gate rate limit: cooldown", function(): ()
    it("first fire passes", function(): ()
        local reg: any = { id = 50010, rateLimit = { cooldown = 10 } }
        local p = fakePlayer("CD1", 5010)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        Gate.clearPlayer(p)
    end)
    it("second fire within cooldown rejects", function(): ()
        local reg: any = { id = 50011, rateLimit = { cooldown = 10 } }
        local p = fakePlayer("CD2", 5011)
        Gate.checkRateLimit(reg, p)
        expect(Gate.checkRateLimit(reg, p)):toBe(false)
        Gate.clearPlayer(p)
    end)
end)

describe("Gate global rate limit", function(): ()
    it("blocks after exceeding global max", function(): ()
        Gate.configureGlobalRateLimit(3)
        local p = fakePlayer("GRL", 5020)
        expect(Gate.checkGlobalRateLimit(p)):toBe(true)
        expect(Gate.checkGlobalRateLimit(p)):toBe(true)
        expect(Gate.checkGlobalRateLimit(p)):toBe(true)
        expect(Gate.checkGlobalRateLimit(p)):toBe(false)
        Gate.clearPlayer(p)
    end)
    it("different players have independent limits", function(): ()
        Gate.configureGlobalRateLimit(2)
        local p1 = fakePlayer("GRL1", 5021)
        local p2 = fakePlayer("GRL2", 5022)
        Gate.checkGlobalRateLimit(p1); Gate.checkGlobalRateLimit(p1)
        expect(Gate.checkGlobalRateLimit(p1)):toBe(false)
        expect(Gate.checkGlobalRateLimit(p2)):toBe(true)
        Gate.clearPlayer(p1); Gate.clearPlayer(p2)
    end)
end)

describe("Gate bandwidth throttle", function(): ()
    it("allows small frames", function(): ()
        Gate.configureBandwidth(1000, 3)
        local p = fakePlayer("BW1", 5030)
        expect(Gate.checkBandwidth(p, 500)):toBe(true)
        Gate.clearPlayer(p)
    end)
    it("accumulates strikes", function(): ()
        Gate.configureBandwidth(100, 2)
        local p = fakePlayer("BW2", 5031)
        expect(Gate.checkBandwidth(p, 200)):toBe(true)
        expect(Gate.checkBandwidth(p, 200)):toBe(true)
        expect(Gate.checkBandwidth(p, 200)):toBe(false)
        Gate.clearPlayer(p)
    end)
    it("decays on small frames", function(): ()
        Gate.configureBandwidth(100, 3)
        local p = fakePlayer("BW3", 5032)
        Gate.checkBandwidth(p, 200) -- +1
        Gate.checkBandwidth(p, 200) -- +2
        Gate.checkBandwidth(p, 50)  -- -1
        Gate.checkBandwidth(p, 50)  -- -1 → 0
        expect(Gate.checkBandwidth(p, 200)):toBe(true) -- +1
        Gate.clearPlayer(p)
    end)
end)

describe("Gate clearPlayer", function(): ()
    it("resets rate limit state", function(): ()
        local reg: any = { id = 50040, rateLimit = { maxPerSecond = 1, burst = 1 } }
        local p = fakePlayer("CP", 5040)
        Gate.checkRateLimit(reg, p)
        expect(Gate.checkRateLimit(reg, p)):toBe(false)
        Gate.clearPlayer(p)
        expect(Gate.checkRateLimit(reg, p)):toBe(true)
        Gate.clearPlayer(p)
    end)
    it("resets global limit", function(): ()
        Gate.configureGlobalRateLimit(1)
        local p = fakePlayer("CP2", 5041)
        Gate.checkGlobalRateLimit(p)
        expect(Gate.checkGlobalRateLimit(p)):toBe(false)
        Gate.clearPlayer(p)
        expect(Gate.checkGlobalRateLimit(p)):toBe(true)
        Gate.clearPlayer(p)
    end)
    it("resets bandwidth strikes", function(): ()
        Gate.configureBandwidth(100, 1)
        local p = fakePlayer("CP3", 5042)
        Gate.checkBandwidth(p, 200)
        expect(Gate.checkBandwidth(p, 200)):toBe(false)
        Gate.clearPlayer(p)
        expect(Gate.checkBandwidth(p, 200)):toBe(true)
        Gate.clearPlayer(p)
    end)
end)

return nil

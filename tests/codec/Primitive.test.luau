--!strict
--!optimize 2
-- Primitive.test.luau — Round-trip tests for all fixed-size numeric and bool codecs.

local Runner = require(script.Parent.Parent.Runner)
local Lync   = require(script.Parent.Parent.Parent)

local describe  = Runner.describe
local it        = Runner.it
local expect    = Runner.expect
local roundTrip = Runner.roundTrip

-- Tests ------------------------------------------------------------------

describe("Primitive.u8", function(): ()
    it("round-trips 0", function(): ()
        expect(roundTrip(Lync.u8, 0)):toBe(0)
    end)
    it("round-trips 255", function(): ()
        expect(roundTrip(Lync.u8, 255)):toBe(255)
    end)
    it("uses exactly 1 byte", function(): ()
        local _, written, consumed = roundTrip(Lync.u8, 42)
        expect(written):toBe(1)
        expect(consumed):toBe(1)
    end)
end)

describe("Primitive.u16", function(): ()
    it("round-trips 0", function(): ()
        expect(roundTrip(Lync.u16, 0)):toBe(0)
    end)
    it("round-trips 65535", function(): ()
        expect(roundTrip(Lync.u16, 65535)):toBe(65535)
    end)
    it("uses exactly 2 bytes", function(): ()
        local _, written, _ = roundTrip(Lync.u16, 1000)
        expect(written):toBe(2)
    end)
end)

describe("Primitive.u32", function(): ()
    it("round-trips 0", function(): ()
        expect(roundTrip(Lync.u32, 0)):toBe(0)
    end)
    it("round-trips max u32", function(): ()
        expect(roundTrip(Lync.u32, 4294967295)):toBe(4294967295)
    end)
    it("uses exactly 4 bytes", function(): ()
        local _, written, _ = roundTrip(Lync.u32, 123456)
        expect(written):toBe(4)
    end)
end)

describe("Primitive.i8", function(): ()
    it("round-trips -128", function(): ()
        expect(roundTrip(Lync.i8, -128)):toBe(-128)
    end)
    it("round-trips 127", function(): ()
        expect(roundTrip(Lync.i8, 127)):toBe(127)
    end)
    it("round-trips 0", function(): ()
        expect(roundTrip(Lync.i8, 0)):toBe(0)
    end)
end)

describe("Primitive.i16", function(): ()
    it("round-trips -32768", function(): ()
        expect(roundTrip(Lync.i16, -32768)):toBe(-32768)
    end)
    it("round-trips 32767", function(): ()
        expect(roundTrip(Lync.i16, 32767)):toBe(32767)
    end)
end)

describe("Primitive.i32", function(): ()
    it("round-trips min i32", function(): ()
        expect(roundTrip(Lync.i32, -2147483648)):toBe(-2147483648)
    end)
    it("round-trips max i32", function(): ()
        expect(roundTrip(Lync.i32, 2147483647)):toBe(2147483647)
    end)
end)

describe("Primitive.f32", function(): ()
    it("round-trips pi at f32 precision", function(): ()
        expect(roundTrip(Lync.f32, math.pi)):toBeCloseTo(math.pi, 0.0001)
    end)
    it("round-trips 0", function(): ()
        expect(roundTrip(Lync.f32, 0)):toBe(0)
    end)
    it("round-trips negative", function(): ()
        expect(roundTrip(Lync.f32, -1.5)):toBeCloseTo(-1.5)
    end)
    it("uses exactly 4 bytes", function(): ()
        local _, written, _ = roundTrip(Lync.f32, 1.0)
        expect(written):toBe(4)
    end)
end)

describe("Primitive.f64", function(): ()
    it("round-trips pi exactly", function(): ()
        expect(roundTrip(Lync.f64, math.pi)):toBe(math.pi)
    end)
    it("round-trips large integer exactly", function(): ()
        expect(roundTrip(Lync.f64, 2 ^ 52)):toBe(2 ^ 52)
    end)
    it("uses exactly 8 bytes", function(): ()
        local _, written, _ = roundTrip(Lync.f64, 0)
        expect(written):toBe(8)
    end)
end)

describe("Primitive.bool", function(): ()
    it("round-trips true", function(): ()
        expect(roundTrip(Lync.bool, true)):toBe(true)
    end)
    it("round-trips false", function(): ()
        expect(roundTrip(Lync.bool, false)):toBe(false)
    end)
    it("uses exactly 1 byte", function(): ()
        local _, written, _ = roundTrip(Lync.bool, true)
        expect(written):toBe(1)
    end)
end)

return nil

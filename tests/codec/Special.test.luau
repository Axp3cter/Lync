--!strict
--!optimize 2
-- Special.test.luau — Round-trip tests for nothing, unknown, and auto codecs.

local Channel = require (script.Parent.Parent.Parent.core.Channel)
local Lync = require (script.Parent.Parent.Parent)
local Runner = require (script.Parent.Parent.Runner)

local describe = Runner.describe
local it = Runner.it
local expect = Runner.expect
local roundTrip = Runner.roundTrip

-- Tests ------------------------------------------------------------------

describe ("Special.nothing", function (): ()
    it ("writes zero bytes", function (): ()
        local _, written, _ = roundTrip (Lync.nothing, "anything")
        expect (written):toBe (0)
    end)
    it ("reads nil", function (): ()
        local result = roundTrip (Lync.nothing, nil)
        expect (result):toBeNil ()
    end)
end)

describe ("Special.auto", function (): ()
    it ("round-trips nil", function (): ()
        expect (roundTrip (Lync.auto, nil)):toBeNil ()
    end)
    it ("round-trips boolean true", function (): ()
        expect (roundTrip (Lync.auto, true)):toBe (true)
    end)
    it ("round-trips boolean false", function (): ()
        expect (roundTrip (Lync.auto, false)):toBe (false)
    end)
    it ("round-trips small integer as u8", function (): ()
        local _, written, _ = roundTrip (Lync.auto, 42)
        expect (written):toBe (2)
        expect (roundTrip (Lync.auto, 42)):toBe (42)
    end)
    it ("round-trips large integer as u32", function (): ()
        expect (roundTrip (Lync.auto, 70000)):toBe (70000)
    end)
    it ("round-trips negative integer as i8", function (): ()
        local _, written, _ = roundTrip (Lync.auto, -5)
        expect (written):toBe (2)
        expect (roundTrip (Lync.auto, -5)):toBe (-5)
    end)
    it ("round-trips float as f32 when lossless", function (): ()
        expect (roundTrip (Lync.auto, 1.5)):toBeCloseTo (1.5)
    end)
    it ("round-trips pi as f64", function (): ()
        expect (roundTrip (Lync.auto, math.pi)):toBe (math.pi)
    end)
    it ("round-trips string", function (): ()
        expect (roundTrip (Lync.auto, "hello")):toBe ("hello")
    end)
    it ("round-trips Vector2", function (): ()
        local result = roundTrip (Lync.auto, Vector2.new (3, 4))
        expect (result.X):toBeCloseTo (3)
        expect (result.Y):toBeCloseTo (4)
    end)
    it ("round-trips Vector3", function (): ()
        local result = roundTrip (Lync.auto, Vector3.new (1, 2, 3))
        expect (result.X):toBeCloseTo (1)
        expect (result.Y):toBeCloseTo (2)
        expect (result.Z):toBeCloseTo (3)
    end)
    it ("round-trips Color3", function (): ()
        local result = roundTrip (Lync.auto, Color3.fromRGB (255, 128, 0))
        expect (result.R):toBeCloseTo (1, 0.01)
        expect (result.G):toBeCloseTo (128 / 255, 0.01)
        expect (result.B):toBeCloseTo (0, 0.01)
    end)
    it ("throws on unsupported type", function (): ()
        expect (function (): ()
            local ch = Channel.create ()
            Lync.auto.write (ch, Instance.new ("Part"))
        end):toThrow ("unsupported type")
    end)
end)

return nil
